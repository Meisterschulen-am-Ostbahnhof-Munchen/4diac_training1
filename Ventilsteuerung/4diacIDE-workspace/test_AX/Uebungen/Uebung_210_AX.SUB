		<Comment Comment="AI_TO_AUDI ist großer Quatsch ... keine Negativen Zahlen möglich" x="300" y="1700" width="2200" height="500"/>
		<AdapterConnections>
			<Connection Source="Input_CU.IN" Destination="AI_FB_CTU.CU" dx1="400"/>
			<Connection Source="Input_R.IN" Destination="AI_FB_CTU.R" dx1="200"/>
			<Connection Source="AI_FB_CTU.Q" Destination="Output_Q1.OUT" dx1="200"/>
			<Connection Source="AI_FB_CTU.CV" Destination="AI_TO_AUDI.AI_IN" dx1="200"/>
			<Connection Source="AI_TO_AUDI.AUDI_OUT" Destination="Q_NumericValue_AUDI.u32NewValue" dx1="200"/>
		</AdapterConnections>
	</SubAppNetwork>
