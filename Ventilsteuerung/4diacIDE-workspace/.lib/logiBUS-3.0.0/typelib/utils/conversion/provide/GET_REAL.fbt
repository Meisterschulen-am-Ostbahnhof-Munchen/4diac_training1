<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="GET_REAL" Comment="Reads a REAL value from an InOut variable and provides it as a buffered Output">
	<Identification Standard="61499-1"/>
	<VersionInfo Version="1.1" Author="franz" Date="2026-05-07" Remarks="Documentation updated"/>
	<CompilerInfo packageName="logiBUS::utils::conversion::provide">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="REQ" Type="Event" Comment="Normal Execution Request">
				<With Var="IN"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="CNF" Type="Event" Comment="Execution Confirmation">
				<With Var="OUT"/>
				<With Var="IN"/>
			</Event>
		</EventOutputs>
		<OutputVars>
			<VarDeclaration Name="OUT" Type="REAL" Comment="Buffered output value" InitialValue="0.0"/>
		</OutputVars>
		<InOutVars>
			<VarDeclaration Name="IN" Type="REAL" Comment="Source variable (InOut)" InitialValue="0.0"/>
		</InOutVars>
	</InterfaceList>
	<SimpleFB>
		<ECState Name="REQ">
			<ECAction Algorithm="REQ" Output="CNF"/>
		</ECState>
		<Algorithm Name="REQ" Comment="Read value from InOut source and store in local buffer">
			<ST><![CDATA[
OUT := IN;
]]></ST>
		</Algorithm>
	</SimpleFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
