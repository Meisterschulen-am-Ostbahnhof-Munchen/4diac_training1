	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-20" Remarks="initial API and implementation - Level based transitions for power-fail recovery"/>
	<CompilerInfo packageName="logiBUS::utils::sequence::boolean">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="logiBUS::utils::sequence::const::sequence"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="S8_START" Type="Event" Comment="jump from State_08 to START"/>
			<Event Name="RESET" Type="Event" Comment="Reset from any State to START"/>
		</EventInputs>
		<EventOutputs>
			<Event Name="CNF" Type="Event" Comment="Execution Confirmation">
				<With Var="STATE_NR"/>
			</Event>
		</EventOutputs>
		<OutputVars>
			<VarDeclaration Name="STATE_NR" Type="SINT" Comment="State Number, START = 0, State_01 = 1 and so on. "/>
		</OutputVars>
		<Sockets>
			<AdapterDeclaration Name="DI_S1" Type="adapter::types::unidirectional::AX" Comment="jump from START to State_01"/>
			<AdapterDeclaration Name="DI_S2" Type="adapter::types::unidirectional::AX" Comment="jump from State_01 to State_02"/>
			<AdapterDeclaration Name="DI_S3" Type="adapter::types::unidirectional::AX" Comment="jump from State_02 to State_03"/>
			<AdapterDeclaration Name="DI_S4" Type="adapter::types::unidirectional::AX" Comment="jump from State_03 to State_04"/>
			<AdapterDeclaration Name="DI_S5" Type="adapter::types::unidirectional::AX" Comment="jump from State_04 to State_05"/>
			<AdapterDeclaration Name="DI_S6" Type="adapter::types::unidirectional::AX" Comment="jump from State_05 to State_06"/>
			<AdapterDeclaration Name="DI_S7" Type="adapter::types::unidirectional::AX" Comment="jump from State_06 to State_07"/>
			<AdapterDeclaration Name="DI_S8" Type="adapter::types::unidirectional::AX" Comment="jump from State_07 to State_08"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="DO_S1" Type="adapter::types::unidirectional::AX" Comment="Output if State_01 is active"/>
			<AdapterDeclaration Name="DO_S2" Type="adapter::types::unidirectional::AX" Comment="Output if State_02 is active"/>
			<AdapterDeclaration Name="DO_S3" Type="adapter::types::unidirectional::AX" Comment="Output if State_03 is active"/>
			<AdapterDeclaration Name="DO_S4" Type="adapter::types::unidirectional::AX" Comment="Output if State_04 is active"/>
			<AdapterDeclaration Name="DO_S5" Type="adapter::types::unidirectional::AX" Comment="Output if State_05 is active"/>
			<AdapterDeclaration Name="DO_S6" Type="adapter::types::unidirectional::AX" Comment="Output if State_06 is active"/>
			<AdapterDeclaration Name="DO_S7" Type="adapter::types::unidirectional::AX" Comment="Output if State_07 is active"/>
			<AdapterDeclaration Name="DO_S8" Type="adapter::types::unidirectional::AX" Comment="Output if State_08 is active"/>
		</Plugs>
	</InterfaceList>
