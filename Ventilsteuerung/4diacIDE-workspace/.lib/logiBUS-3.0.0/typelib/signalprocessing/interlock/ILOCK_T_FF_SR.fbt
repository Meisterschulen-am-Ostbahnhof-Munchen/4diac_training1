<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ILOCK_T_FF_SR" Comment="Composite FB for a lockable toggle flip-flop with AE2 adapter interface">
	<Identification Standard="61499-2" Description="Copyright (c) 2023 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-19" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="logiBUS::signalprocessing::interlock">
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="S" Type="Event" Comment="Set output Q">
			</Event>
			<Event Name="R" Type="Event" Comment="Reset output Q">
			</Event>
			<Event Name="CLK" Type="Event" Comment="Clock for triggering a output toggle">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="EO" Type="Event">
			</Event>
		</EventOutputs>
		<OutputVars>
			<VarDeclaration Name="Q" Type="BOOL" Comment="Output"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="ILOCK_OUT" Type="adapter::types::bidirectional::AE2" x="1700" y="600"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="ILOCK_IN" Type="adapter::types::bidirectional::AE2" x="1700" y="200"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_SR" Type="iec61499::events::E_SR" x="2700" y="-700">
		</FB>
		<FB Name="E_SWITCH" Type="iec61499::events::E_SWITCH" x="-1100" y="-700">
		</FB>
		<FB Name="E_MERGE_2" Type="iec61499::events::E_MERGE_2" x="200" y="-1100">
		</FB>
		<EventConnections>
			<Connection Source="E_SWITCH.EO1" Destination="E_SR.R"/>
			<Connection Source="E_SR.EO" Destination="EO" dx1="780"/>
			<Connection Source="ILOCK_IN.EO1" Destination="E_SR.R" dx1="493.33"/>
			<Connection Source="ILOCK_OUT.EI1" Destination="E_SR.R" dx1="493.33"/>
			<Connection Source="CLK" Destination="E_SWITCH.EI" dx1="680"/>
			<Connection Source="R" Destination="E_SR.R" dx1="2220"/>
			<Connection Source="E_MERGE_2.EO" Destination="E_SR.S" dx1="1266.67"/>
			<Connection Source="E_MERGE_2.EO" Destination="ILOCK_IN.EI1" dx1="146.67"/>
			<Connection Source="E_MERGE_2.EO" Destination="ILOCK_OUT.EO1" dx1="146.67"/>
			<Connection Source="E_SWITCH.EO0" Destination="E_MERGE_2.EI2" dx1="380"/>
			<Connection Source="S" Destination="E_MERGE_2.EI1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="E_SR.Q" Destination="E_SWITCH.G" dx1="80" dx2="80" dy="160"/>
			<Connection Source="E_SR.Q" Destination="Q" dx1="1306.67"/>
		</DataConnections>
	</FBNetwork>
</FBType>
