<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="FIELDBUS_LWORD_TO_SIGNAL_SCALED" Comment="Mirrors IN-&gt;OUT if Signal Valid, with scaling">
	<Identification Standard="61499-1" Description="Copyright (c) 2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0 ">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-31">
	</VersionInfo>
	<CompilerInfo packageName="logiBUS::signalprocessing::fieldbus">
		<Import declaration="signalprocessing::FIELDBUS_SIGNAL::NOT_AVAILABLE_LM"/>
		<Import declaration="signalprocessing::FIELDBUS_SIGNAL::VALID_SIGNAL_LW"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Init Request">
				<With Var="SCALE"/>
				<With Var="OFFSET"/>
			</Event>
			<Event Name="REQ" Type="Event" Comment="Normal Execution Request">
				<With Var="IN"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Init Confirmation">
			</Event>
			<Event Name="CNF" Type="Event" Comment="Execution Confirmation">
				<With Var="OUT"/>
				<With Var="VALID"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="IN" Type="LWORD" Comment="Input" InitialValue="NOT_AVAILABLE_LM"/>
			<VarDeclaration Name="SCALE" Type="REAL" Comment="Scaling factor" InitialValue="REAL#1.0"/>
			<VarDeclaration Name="OFFSET" Type="DINT" Comment="Offset added after scaling" InitialValue="DINT#0"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="OUT" Type="LREAL" Comment="Output Scaled" InitialValue="LREAL#0.0"/>
			<VarDeclaration Name="VALID" Type="BOOL" Comment="TRUE if Signal is VALID" InitialValue="FALSE"/>
		</OutputVars>
	</InterfaceList>
	<SimpleFB>
		<ECState Name="INIT">
			<ECAction Algorithm="INIT" Output="INITO"/>
		</ECState>
		<ECState Name="REQ">
			<ECAction Algorithm="REQ" Output="CNF"/>
		</ECState>
		<Algorithm Name="INIT">
			<ST><![CDATA[
]]></ST>
		</Algorithm>
		<Algorithm Name="REQ" Comment="Executed algorithm">
			<ST><![CDATA[

IF (LWORD_TO_ULINT(IN) <= LWORD_TO_ULINT(VALID_SIGNAL_LW)) THEN
	OUT := LWORD_TO_LREAL(IN) * SCALE + DINT_TO_LREAL(OFFSET);
	VALID := BOOL#TRUE;
ELSE
	OUT := LREAL#0.0;
	VALID := BOOL#FALSE;
END_IF;

]]></ST>
		</Algorithm>
	</SimpleFB>
</FBType>
