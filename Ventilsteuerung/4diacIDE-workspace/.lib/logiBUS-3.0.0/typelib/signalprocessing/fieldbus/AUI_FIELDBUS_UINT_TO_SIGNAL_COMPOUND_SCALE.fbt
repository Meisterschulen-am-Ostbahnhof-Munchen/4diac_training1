<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AUI_FIELDBUS_UINT_TO_SIGNAL_COMPOUND_SCALE" Comment="Mirrors IN-&gt;OUT if Signal Valid, with compound scaling for upper and lower byte">
