<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="E_D_FF_ANY_HYS_TMIN" Comment="Data latch (d) flip flop with a Hysteresis, with a Minimum inter-disposal Time between EO">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10;&#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-14" Remarks="Inital API">
	</VersionInfo>
	<CompilerInfo packageName="logiBUS::signalprocessing::hysteresis">
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Init Request">
				<With Var="Tmin"/>
			</Event>
			<Event Name="CLK" Type="Event" Comment="Clock">
				<With Var="D"/>
				<With Var="HYSTERESIS"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Init Confirmation">
			</Event>
			<Event Name="EO" Type="Event" Comment="Triggered if clock results in a change of Q">
				<With Var="Q"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="D" Type="ANY_NUM" Comment="Value to latch"/>
			<VarDeclaration Name="HYSTERESIS" Type="ANY_NUM" Comment="Hysteresis band"/>
			<VarDeclaration Name="Tmin" Type="TIME" Comment="Minimum inter-arrival time between EI events"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="Q" Type="ANY_NUM" Comment="Latched value"/>
		</OutputVars>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_D_FF_ANY_HYS" Type="logiBUS::signalprocessing::hysteresis::E_D_FF_ANY_HYS" x="900" y="400">
		</FB>
		<FB Name="E_TMIN" Type="iec61499::events::E_TMIN" x="2100" y="1000">
		</FB>
		<EventConnections>
			<Connection Source="CLK" Destination="E_D_FF_ANY_HYS.CLK" dx1="1606.67"/>
			<Connection Source="INIT" Destination="E_TMIN.INIT" dx1="2253.33"/>
			<Connection Source="E_TMIN.INITO" Destination="INITO" dx1="1166.67"/>
			<Connection Source="E_TMIN.EO" Destination="EO" dx1="1773.33"/>
			<Connection Source="E_D_FF_ANY_HYS.EO" Destination="E_TMIN.EI" dx1="220"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="E_D_FF_ANY_HYS.Q" Destination="Q" dx1="3080"/>
			<Connection Source="D" Destination="E_D_FF_ANY_HYS.D" dx1="866.67"/>
			<Connection Source="Tmin" Destination="E_TMIN.Tmin" dx1="566.67"/>
			<Connection Source="HYSTERESIS" Destination="E_D_FF_ANY_HYS.HYSTERESIS" dx1="706.67"/>
		</DataConnections>
	</FBNetwork>
</FBType>
