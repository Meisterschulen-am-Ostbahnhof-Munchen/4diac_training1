<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="FT_PT1" Comment="Low Pass Filter (PT1)">
	<Identification Standard="61499-1" Description="FT_PT1 is an low pass filter with a programmable time T and faktor K."/>
	<VersionInfo Version="1.0" Author="Franz Höpfinger" Date="2025-12-21" Remarks="initial API and implementation and/or initial documentation"/>
	<CompilerInfo packageName="OSCAT::Basic::POUs::Engineering::Control">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="OSCAT::Basic::POUs::Engineering::measurements::T_PLC_US"/>
		<Import declaration="OSCAT::Basic::POUs::conversion::TIME_TO_REAL"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="EINIT" Type="EInit" Comment="Init Request"/>
			<Event Name="REQ" Type="Event" Comment="Normal Execution Request">
				<With Var="in"/>
				<With Var="TM"/>
				<With Var="K"/>
			</Event>
			<Event Name="RST" Type="Event" Comment="Reset"/>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Init Confirmation"/>
			<Event Name="CNF" Type="Event" Comment="Execution Confirmation">
				<With Var="delta_t"/>
				<With Var="out"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="in" Type="REAL" Comment="Input Signal"/>
			<VarDeclaration Name="TM" Type="TIME" Comment="Filter Time Constant"/>
			<VarDeclaration Name="K" Type="REAL" Comment="Gain Factor" InitialValue="1.0"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="delta_t" Type="UDINT" Comment="Delta T since last call."/>
			<VarDeclaration Name="out" Type="REAL" Comment="Output Signal"/>
		</OutputVars>
	</InterfaceList>
	<SimpleFB>
		<InternalVars>
			<VarDeclaration Name="last" Type="UDINT" Comment="Last execution time"/>
			<VarDeclaration Name="tx" Type="UDINT" Comment="Current execution time"/>
			<VarDeclaration Name="init" Type="BOOL" Comment="Initialization flag"/>
		</InternalVars>
		<ECState Name="EINIT" Comment="Initialization">
			<ECAction Algorithm="EINIT" Output="INITO"/>
		</ECState>
		<ECState Name="REQ" Comment="Normal Operation">
			<ECAction Algorithm="REQ" Output="CNF"/>
		</ECState>
		<ECState Name="RST">
			<ECAction Algorithm="RST" Output="CNF"/>
		</ECState>
		<Algorithm Name="EINIT">
			<ST><![CDATA[
(* Reset logic *)
init := FALSE;
out := 0.0;
last := UDINT#0;
]]></ST>
		</Algorithm>
		<Algorithm Name="RST">
			<ST><![CDATA[
init := TRUE;
out := K * in;
]]></ST>
		</Algorithm>
		<Algorithm Name="REQ">
			<ST><![CDATA[
(* Read system time *)
tx := T_PLC_US();

(* Startup initialization or T=0 *)
IF NOT init OR TM = T#0s THEN
	this.RST();
ELSE
	(* Calculate time delta since last call *)
	delta_t := (tx - last);

		(* PT1 Formula: out = out + (target - out) * (dt / T) *)
	IF TIME_TO_REAL(TM) > 0.0 THEN
		out := out + (in * K - out) * UDINT_TO_REAL(delta_t) / TIME_TO_REAL(TM);
	END_IF;

		(* Avoid denormalized numbers / underrun *)
	IF ABS(out) < 1.0E-20 THEN
		out := 0.0;
	END_IF;
END_IF;

(* Save time for next cycle *)
last := tx;

]]></ST>
		</Algorithm>
	</SimpleFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
