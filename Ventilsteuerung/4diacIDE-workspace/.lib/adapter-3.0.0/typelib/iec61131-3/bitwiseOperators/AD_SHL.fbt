<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AD_SHL" Comment="FB to calculate bitwise SHL (generic FB)">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.1" Author="Franz Höpfinger" Date="2026-04-20" Remarks="Added UPDATE event for N to satisfy Basic FB / logic rules">
	</VersionInfo>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-20" Remarks="initial API and implementation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::iec61131::bitwise">
		<Import declaration="eclipse4diac::core::GenericClassName"/>
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="UPDATE" Type="Event" Comment="Update shift count">
				<With Var="N"/>
			</Event>
		</EventInputs>
		<InputVars>
			<VarDeclaration Name="N" Type="ANY_INT" Comment="Number of bits to shift"/>
		</InputVars>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AD" Comment="SHL result" x="2400" y="500"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="IN" Type="adapter::types::unidirectional::AD" Comment="SHL input" x="-500" y="1200"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="F_SHL" Type="iec61131::bitwiseOperators::F_SHL" x="700" y="393.33">
		</FB>
		<EventConnections>
			<Connection Source="F_SHL.CNF" Destination="OUT.E1" dx1="586.67"/>
			<Connection Source="IN.E1" Destination="F_SHL.REQ" dx1="200"/>
			<Connection Source="UPDATE" Destination="F_SHL.REQ" dx1="1506.67"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="F_SHL.OUT" Destination="OUT.D1" dx1="586.67"/>
			<Connection Source="IN.D1" Destination="F_SHL.IN" dx1="506.67"/>
			<Connection Source="N" Destination="F_SHL.N" dx1="1506.67"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
