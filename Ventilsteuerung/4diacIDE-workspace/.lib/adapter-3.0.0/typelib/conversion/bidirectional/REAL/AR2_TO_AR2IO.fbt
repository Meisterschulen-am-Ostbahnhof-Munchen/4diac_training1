	</VersionInfo>
	<CompilerInfo packageName="adapter::conversion::bidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="AR2IO_OUT" Type="adapter::types::bidirectional::AR2IO" Comment="AR2IO Adapter Output">
				<Parameter Name="D1" Value="0.0"/>
			</AdapterDeclaration>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="AR2_IN" Type="adapter::types::bidirectional::AR2" Comment="AR2 Adapter Input"/>
		</Sockets>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="550" y="425">
			</ECState>
			<ECState Name="GET" x="2760" y="513.33">
				<ECAction Algorithm="GET" Output="AR2_IN.EI1"/>
			</ECState>
			<ECState Name="SET" x="2720" y="1040">
				<ECAction Algorithm="SET" Output="AR2IO_OUT.EO1"/>
			</ECState>
			<ECTransition Source="START" Destination="GET" Condition="AR2IO_OUT.EI1" Comment="" x="1655" y="469.17"/>
			<ECTransition Source="START" Destination="SET" Condition="AR2_IN.EO1" Comment="" x="1540" y="846.67"/>
			<ECTransition Source="GET" Destination="START" Condition="1" Comment="" x="1726.67" y="646.67"/>
			<ECTransition Source="SET" Destination="START" Condition="1" Comment="" x="1440" y="1146.67"/>
		</ECC>
		<Algorithm Name="GET">
			<ST><![CDATA[
AR2IO_OUT.D1 := AR2_IN.DO1;
]]></ST>
		</Algorithm>
		<Algorithm Name="SET">
			<ST><![CDATA[
AR2_IN.DI1 := AR2IO_OUT.D1;
]]></ST>
		</Algorithm>
	</BasicFB>
</FBType>
