<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AW_TO_AD" Comment="Composite FB for converting AW (WORD) adapter to AD (DWORD) adapter">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0"/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-02-17"/>
	<CompilerInfo packageName="adapter::conversion::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Sockets>
			<AdapterDeclaration Name="AW_IN" Type="adapter::types::unidirectional::AW" Comment="WORD Adapter Input" x="0" y="0"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="AD_OUT" Type="adapter::types::unidirectional::AD" Comment="DWORD Adapter Output" x="2000" y="0"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<EventConnections>
			<Connection Source="AW_IN.E1" Destination="AD_OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="AW_IN.D1" Destination="AD_OUT.D1"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
