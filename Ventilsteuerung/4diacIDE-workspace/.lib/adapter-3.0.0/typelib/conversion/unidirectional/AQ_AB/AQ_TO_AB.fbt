<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AQ_TO_AB" Comment="Converts an AQ (Quarter Byte) adapter to an AB (BYTE) adapter">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-05-16" Remarks="Initial Version">
	</VersionInfo>
	<CompilerInfo packageName="adapter::conversion::unidirectional">
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AB" Comment="BYTE Output" x="2000" y="0"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="IN" Type="adapter::types::unidirectional::AQ" Comment="AQ Input" x="0" y="0"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_D_FF" Type="iec61499::events::E_D_FF_ANY" x="900" y="0"/>
		<EventConnections>
			<Connection Source="IN.E1" Destination="E_D_FF.CLK"/>
			<Connection Source="E_D_FF.EO" Destination="OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="IN.D1" Destination="E_D_FF.D"/>
			<Connection Source="E_D_FF.Q" Destination="OUT.D1"/>
		</DataConnections>
	</FBNetwork>
</FBType>
