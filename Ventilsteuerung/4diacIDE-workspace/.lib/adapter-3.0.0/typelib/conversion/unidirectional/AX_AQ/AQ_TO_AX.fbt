<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AQ_TO_AX" Comment="Converts an AQ (Quarter Byte) adapter to an AX (BOOL) adapter using STATUS logic">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-05-16" Remarks="Initial Version">
	</VersionInfo>
	<CompilerInfo packageName="adapter::conversion::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AX" Comment="BOOL Output" x="2500" y="0"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="IN" Type="adapter::types::unidirectional::AQ" Comment="AQ Input" x="0" y="0"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="QUARTER_TO_BOOL" Type="logiBUS::utils::quarter::QUARTER_TO_BOOL" x="1000" y="0">
		</FB>
		<EventConnections>
			<Connection Source="IN.E1" Destination="QUARTER_TO_BOOL.REQ"/>
			<Connection Source="QUARTER_TO_BOOL.CNF" Destination="OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="IN.D1" Destination="QUARTER_TO_BOOL.IB"/>
			<Connection Source="QUARTER_TO_BOOL.Q" Destination="OUT.D1"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
