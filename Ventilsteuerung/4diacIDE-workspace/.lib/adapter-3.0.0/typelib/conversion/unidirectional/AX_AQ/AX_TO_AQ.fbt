<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AX_TO_AQ" Comment="Converts an AX (BOOL) adapter to an AQ (Quarter Byte) adapter using COMMAND logic">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-05-16" Remarks="Initial Version">
	</VersionInfo>
	<CompilerInfo packageName="adapter::conversion::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AQ" Comment="AQ Output" x="2500" y="0"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="IN" Type="adapter::types::unidirectional::AX" Comment="BOOL Input" x="0" y="0"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="BOOL_TO_QUARTER" Type="logiBUS::utils::quarter::BOOL_TO_QUARTER" x="1000" y="0"/>
		<EventConnections>
			<Connection Source="IN.E1" Destination="BOOL_TO_QUARTER.REQ"/>
			<Connection Source="BOOL_TO_QUARTER.CNF" Destination="OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="IN.D1" Destination="BOOL_TO_QUARTER.I"/>
			<Connection Source="BOOL_TO_QUARTER.QB" Destination="OUT.D1"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
