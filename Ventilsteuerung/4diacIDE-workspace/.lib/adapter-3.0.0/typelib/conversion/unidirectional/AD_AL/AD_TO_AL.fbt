<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AD_TO_AL" Comment="Composite FB for converting AD (DWORD) adapter to AL (LWORD) adapter">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-02-17">
	</VersionInfo>
	<CompilerInfo packageName="adapter::conversion::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="AL_OUT" Type="adapter::types::unidirectional::AL" Comment="LWORD Adapter Output" x="2300" y="0"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="AD_IN" Type="adapter::types::unidirectional::AD" Comment="DWORD Adapter Input" x="0" y="0"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<EventConnections>
			<Connection Source="AD_IN.E1" Destination="AL_OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="AD_IN.D1" Destination="AL_OUT.D1"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
