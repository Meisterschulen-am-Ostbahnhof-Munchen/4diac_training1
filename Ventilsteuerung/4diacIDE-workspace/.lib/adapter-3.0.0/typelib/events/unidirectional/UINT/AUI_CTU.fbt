<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AUI_CTU" Comment="Event driven up counter (Adapter Version) - On Change Triggering">
	<Identification Standard="61499-1 Annex 2" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10; &#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Version="3.2" Author="Franz Höpfinger" Date="2026-04-19" Remarks="Made Q event triggering on-change only via internal state tracking">
	</VersionInfo>
	<VersionInfo Version="3.1" Author="Franz Höpfinger" Date="2026-04-19" Remarks="Added status event for Q adapter and PV update logic">
	</VersionInfo>
	<VersionInfo Version="3.0" Author="Patrick Aigner" Date="2025-04-14" Remarks="changed package">
	</VersionInfo>
	<VersionInfo Organization="fortiss GmbH" Version="1.0" Author="Alois Zoitl" Date="2017-09-21" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::events::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="CU" Type="Event" Comment="Count up">
			</Event>
			<Event Name="R" Type="Event" Comment="Reset">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="CUO" Type="Event" Comment="Count up output">
			</Event>
			<Event Name="RO" Type="Event" Comment="Reset output">
			</Event>
		</EventOutputs>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="True if CV &gt;= PV"/>
			<AdapterDeclaration Name="CV" Type="adapter::types::unidirectional::AUI" Comment="Counter Value"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="PV" Type="adapter::types::unidirectional::AUI" Comment="Process Value"/>
		</Sockets>
	</InterfaceList>
	<BasicFB>
		<InternalVars>
			<VarDeclaration Name="Q_OLD" Type="BOOL" Comment="Stores the previous state of the output Q to detect changes (On-Change triggering)" InitialValue="FALSE">
				<Attribute Name="Retain" Value="NON_RETAIN"/>
			</VarDeclaration>
		</InternalVars>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="1413.33" y="1186.67">
			</ECState>
			<ECState Name="CU" Comment="Count Up" x="3680" y="160">
				<ECAction Algorithm="CU" Output="CV.E1"/>
				<ECAction Output="CUO"/>
			</ECState>
			<ECState Name="R" Comment="Reset" x="1840" y="2640">
				<ECAction Algorithm="R" Output="CV.E1"/>
				<ECAction Output="RO"/>
			</ECState>
			<ECState Name="UPDATE_PV" Comment="Re-evaluate Q on PV change" x="4240" y="2320">
				<ECAction Algorithm="UPDATE"/>
			</ECState>
			<ECState Name="EMIT_Q" Comment="Fires Q event and saves state" x="3920" y="1200">
				<ECAction Algorithm="SAVE_Q" Output="Q.E1"/>
			</ECState>
			<ECTransition Source="START" Destination="CU" Condition="CU[CV.D1 &lt; 65535]" x="1693.33" y="553.33"/>
			<ECTransition Source="CU" Destination="EMIT_Q" Condition="[Q.D1 &lt;&gt; Q_OLD]" x="3746.67" y="826.67"/>
			<ECTransition Source="CU" Destination="START" Condition="[Q.D1 = Q_OLD]" x="1980" y="746.67"/>
			<ECTransition Source="START" Destination="R" Condition="R" x="1613.33" y="1940"/>
			<ECTransition Source="R" Destination="EMIT_Q" Condition="[Q.D1 &lt;&gt; Q_OLD]" x="2166.67" y="2000"/>
			<ECTransition Source="R" Destination="START" Condition="[Q.D1 = Q_OLD]" x="1153.33" y="2146.67"/>
			<ECTransition Source="START" Destination="UPDATE_PV" Condition="PV.E1" x="3526.67" y="1886.67"/>
			<ECTransition Source="UPDATE_PV" Destination="EMIT_Q" Condition="[Q.D1 &lt;&gt; Q_OLD]" x="4026.67" y="1773.33"/>
			<ECTransition Source="UPDATE_PV" Destination="START" Condition="[Q.D1 = Q_OLD]" x="3333.33" y="2213.33"/>
			<ECTransition Source="EMIT_Q" Destination="START" Condition="1" x="2660" y="1213.33"/>
		</ECC>
		<Algorithm Name="R" Comment="reset counter">
			<ST><![CDATA[
CV.D1 := 0;
Q.D1 := (CV.D1 >= PV.D1);
]]></ST>
		</Algorithm>
		<Algorithm Name="CU" Comment="count up">
			<ST><![CDATA[
CV.D1 := CV.D1 + 1;
Q.D1 := (CV.D1 >= PV.D1);
]]></ST>
		</Algorithm>
		<Algorithm Name="UPDATE" Comment="update status only">
			<ST><![CDATA[
Q.D1 := (CV.D1 >= PV.D1);
]]></ST>
		</Algorithm>
		<Algorithm Name="SAVE_Q" Comment="save state">
			<ST><![CDATA[
Q_OLD := Q.D1;
]]></ST>
		</Algorithm>
	</BasicFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
