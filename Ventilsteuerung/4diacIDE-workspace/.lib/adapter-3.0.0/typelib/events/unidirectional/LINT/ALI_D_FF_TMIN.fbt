<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ALI_D_FF_TMIN" Comment="Data latch (d) flip flop, with a Minimum inter-disposal Time between EO">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10;&#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-15" Remarks="Inital API">
	</VersionInfo>
	<CompilerInfo packageName="adapter::events::unidirectional">
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Init Request">
				<With Var="Tmin"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Init Confirmation">
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="Tmin" Type="TIME" Comment="Minimum inter-arrival time between EI events"/>
		</InputVars>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::ALI" Comment="Latched value" x="2000" y="-900"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="I" Type="adapter::types::unidirectional::ALI" Comment="Value to latch" x="-1200" y="-800"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_D_FF_ANY_TMIN" Type="iec61499::events::E_D_FF_ANY_TMIN" x="400" y="-1100">
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="E_D_FF_ANY_TMIN.INIT" dx1="80"/>
			<Connection Source="E_D_FF_ANY_TMIN.INITO" Destination="INITO" dx1="3233.33"/>
			<Connection Source="I.E1" Destination="E_D_FF_ANY_TMIN.CLK" dx1="560"/>
			<Connection Source="E_D_FF_ANY_TMIN.EO" Destination="Q.E1" dx1="400"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="Tmin" Destination="E_D_FF_ANY_TMIN.Tmin" dx1="1980"/>
			<Connection Source="I.D1" Destination="E_D_FF_ANY_TMIN.D" dx1="560"/>
			<Connection Source="E_D_FF_ANY_TMIN.Q" Destination="Q.D1" dx1="400"/>
		</DataConnections>
	</FBNetwork>
</FBType>
