<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ATM_AX_PULSE" Comment="Standard timer function block (pulse) - non-retriggerable">
	<Identification Standard="61499-2" Description="Copyright (c) 2023, 2024 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0  &#10;   &#10;   &#10;AX_PULSE -- Impulse forming FB with AX adapter interface  &#10;&#10;Generate an Impulse with a given Time.  &#10;This FB makes an Impulse of Duration PT on the Output Q.  &#10;Non-retriggerable.">
	</Identification>
	<VersionInfo Version="3.0" Author="Patrick Aigner" Date="2025-04-14" Remarks="changed package">
	</VersionInfo>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.1" Author="Franz Höpfinger" Date="2024-04-23" Remarks="Add a Reset to Timer FBs">
	</VersionInfo>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0.1" Author="Franz Höpfinger" Date="2024-03-05" Remarks="renamed to E_PULSE">
	</VersionInfo>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2023-08-21" Remarks="initial implementation as E_IMPULSE">
	</VersionInfo>
	<CompilerInfo packageName="adapter::events::unidirectional::timers">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="REQ" Type="Event" Comment="Service Request">
			</Event>
			<Event Name="R" Type="Event" Comment="Reset">
			</Event>
		</EventInputs>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="Timer output (AX adapter)" x="600" y="-600"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="PT" Type="adapter::types::unidirectional::ATM" Comment="Pulse time" x="-1600" y="-200"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_PULSE" Type="iec61499::events::timers::E_PULSE" x="-600" y="-500">
		</FB>
		<EventConnections>
			<Connection Source="E_PULSE.CNF" Destination="Q.E1" dx1="293.33"/>
			<Connection Source="REQ" Destination="E_PULSE.REQ" dx1="926.67"/>
			<Connection Source="R" Destination="E_PULSE.R" dx1="780"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="E_PULSE.Q" Destination="Q.D1" dx1="293.33"/>
			<Connection Source="PT.D1" Destination="E_PULSE.PT" dx1="460"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
