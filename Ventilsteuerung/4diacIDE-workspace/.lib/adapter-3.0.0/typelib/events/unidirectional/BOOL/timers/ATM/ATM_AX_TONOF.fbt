<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ATM_AX_TONOF" Comment="Standard timer function block (on/off-delay timing)">
	<Identification Standard="61499-2" Classification="standard timer function block" Description="Copyright (c) 2024 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0  &#10;   &#10;   &#10;AT_AX_TONOF -- On/Off-delay timer FB with AX/AT adapter interface  &#10;&#10;The adapter input IN triggers execution (E1-&gt;REQ) and provides  &#10;the boolean input value (D1-&gt;IN). The adapter inputs PT_ON and PT_OFF  &#10;provide the delay times (D1-&gt;PT_ON/PT_OFF). The event input R resets the timer.  &#10;When IN goes TRUE, Q becomes TRUE after delay PT_ON.  &#10;When IN goes FALSE, Q becomes FALSE after delay PT_OFF.  &#10;Reset stops both timers and sets Q to FALSE."/>
	<VersionInfo Version="3.0" Author="Patrick Aigner" Date="2025-04-14" Remarks="changed package"/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.1" Author="Franz Höpfinger" Date="2024-04-23" Remarks="Add a Reset to Timer FBs"/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2024-03-04"/>
	<CompilerInfo packageName="adapter::events::unidirectional::timers">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="R" Type="Event" Comment="Reset"/>
		</EventInputs>
		<Sockets>
			<AdapterDeclaration Name="IN" Type="adapter::types::unidirectional::AX" Comment="Timer input (AX adapter)" x="-4200" y="-1200"/>
			<AdapterDeclaration Name="PT_ON" Type="adapter::types::unidirectional::ATM" Comment="ON delay time (AT adapter)" x="-4200" y="-700"/>
			<AdapterDeclaration Name="PT_OFF" Type="adapter::types::unidirectional::ATM" Comment="OFF delay time (AT adapter)" x="-4200" y="-200"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="Timer output (AX adapter)" x="-1800" y="-900"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_TONOF" Type="iec61499::events::timers::E_TONOF" x="-3100" y="-1000"/>
		<EventConnections>
			<Connection Source="R" Destination="E_TONOF.R" dx1="633.33"/>
			<Connection Source="IN.E1" Destination="E_TONOF.REQ" dx1="360"/>
			<Connection Source="E_TONOF.CNF" Destination="Q.E1" dx1="340"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="PT_ON.D1" Destination="E_TONOF.PT_ON" dx1="593.33"/>
			<Connection Source="PT_OFF.D1" Destination="E_TONOF.PT_OFF" dx1="593.33"/>
			<Connection Source="IN.D1" Destination="E_TONOF.IN" dx1="360"/>
			<Connection Source="E_TONOF.Q" Destination="Q.D1" dx1="340"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
