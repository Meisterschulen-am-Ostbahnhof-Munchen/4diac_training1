<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AX_PULSE_RETRIG" Comment="Standard timer function block (pulse) - retriggerable version">
	<Identification Standard="61499-2" Description="Copyright (c) 2023 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0  &#10;   &#10;   &#10;AX_PULSE_RETRIG -- Impulse forming FB with AX adapter interface (Retriggerable) &#10;&#10;Generate an Impulse with a given Time.  &#10;This FB makes an Impulse of Duration PT on the Output Q. New REQ restarts the timer."/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-19" Remarks="retriggerable version"/>
	<CompilerInfo packageName="adapter::events::unidirectional::timers">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="REQ" Type="Event" Comment="Service Request (Restarts the timer)">
				<With Var="PT"/>
			</Event>
			<Event Name="R" Type="Event" Comment="Reset"/>
		</EventInputs>
		<InputVars>
			<VarDeclaration Name="PT" Type="TIME" Comment="Pulse time"/>
		</InputVars>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="Timer output (AX adapter)" x="1500" y="-400"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_PULSE_RETRIG" Type="iec61499::events::timers::E_PULSE_RETRIG" x="-600" y="-500"/>
		<EventConnections>
			<Connection Source="E_PULSE_RETRIG.CNF" Destination="Q.E1" dx1="293.33"/>
			<Connection Source="REQ" Destination="E_PULSE_RETRIG.REQ" dx1="926.67"/>
			<Connection Source="R" Destination="E_PULSE_RETRIG.R" dx1="780"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="E_PULSE_RETRIG.Q" Destination="Q.D1" dx1="293.33"/>
			<Connection Source="PT" Destination="E_PULSE_RETRIG.PT" dx1="646.67"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
