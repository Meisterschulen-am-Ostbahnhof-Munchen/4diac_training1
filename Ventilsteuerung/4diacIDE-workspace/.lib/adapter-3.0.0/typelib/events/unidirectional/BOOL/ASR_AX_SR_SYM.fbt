	<CompilerInfo packageName="adapter::events::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<Sockets>
			<AdapterDeclaration Name="S_R" Type="adapter::types::unidirectional::ASR" Comment="Set/Reset"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="value of flip flop"/>
		</Plugs>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="240" y="640"/>
			<ECState Name="SET" x="1200" y="400">
				<ECAction Algorithm="SET" Output="Q.E1"/>
			</ECState>
			<ECState Name="RESET" x="1200" y="1440">
				<ECAction Algorithm="RESET" Output="Q.E1"/>
			</ECState>
			<ECTransition Source="START" Destination="SET" Condition="S_R.SET" x="713.33" y="453.33"/>
			<ECTransition Source="SET" Destination="RESET" Condition="S_R.RESET" x="1113.33" y="966.67"/>
			<ECTransition Source="RESET" Destination="SET" Condition="S_R.SET" x="1740" y="953.33"/>
			<ECTransition Source="START" Destination="RESET" Condition="S_R.RESET" x="633.33" y="1240"/>
		</ECC>
		<Algorithm Name="SET">
			<ST><![CDATA[
Q.D1 := TRUE;
]]></ST>
		</Algorithm>
		<Algorithm Name="RESET">
			<ST><![CDATA[
Q.D1 := FALSE;
]]></ST>
		</Algorithm>
	</BasicFB>
