	<CompilerInfo packageName="adapter::events::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventOutputs>
			<Event Name="EO" Type="Event" Comment="confirmation that an rising edge was detected"/>
		</EventOutputs>
		<Sockets>
			<AdapterDeclaration Name="QI" Type="adapter::types::unidirectional::AX" Comment="value to check for a rising edge" x="-600" y="100"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_R_TRIG" Type="iec61499::events::E_R_TRIG" x="600" y="100"/>
		<EventConnections>
			<Connection Source="QI.E1" Destination="E_R_TRIG.EI"/>
			<Connection Source="E_R_TRIG.EO" Destination="EO" dx1="1940"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="QI.D1" Destination="E_R_TRIG.QI"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
