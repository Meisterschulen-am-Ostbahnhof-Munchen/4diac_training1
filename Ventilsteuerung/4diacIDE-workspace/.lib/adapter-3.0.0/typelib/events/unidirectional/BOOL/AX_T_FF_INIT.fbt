<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AX_T_FF_INIT" Comment="Toggle flip flop and INIT">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10; &#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Version="3.0" Author="Patrick Aigner" Date="2025-04-14" Remarks="changed package">
	</VersionInfo>
	<VersionInfo Organization="fortiss GmbH" Version="1.0" Author="Alois Zoitl" Date="2017-09-22" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::events::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Initialization Request">
				<With Var="QI"/>
				<With Var="Q_INIT"/>
			</Event>
			<Event Name="CLK" Type="Event" Comment="Clock for triggering a output toggle">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
				<With Var="QO"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="QI" Type="BOOL" Comment="Input event qualifier"/>
			<VarDeclaration Name="Q_INIT" Type="BOOL" Comment="Value of Q at INIT"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="QO" Type="BOOL" Comment="Output event qualifier"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AX" Comment="value of flip flop"/>
		</Plugs>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="1920" y="640">
			</ECState>
			<ECState Name="Init" Comment="Initialization" x="2880" y="480">
				<ECAction Algorithm="initialize" Output="INITO"/>
			</ECState>
			<ECState Name="DeInit" x="2880" y="880">
				<ECAction Algorithm="deInitialize" Output="INITO"/>
			</ECState>
			<ECState Name="SET" x="5233.33" y="1073.33">
				<ECAction Algorithm="SET" Output="Q.E1"/>
			</ECState>
			<ECState Name="RESET" x="5200" y="1520">
				<ECAction Algorithm="RESET" Output="Q.E1"/>
			</ECState>
			<ECTransition Source="SET" Destination="RESET" Condition="CLK" x="5706.67" y="1340"/>
			<ECTransition Source="RESET" Destination="SET" Condition="CLK" x="4920" y="1366.67"/>
			<ECTransition Source="START" Destination="Init" Condition="INIT[TRUE = QI]" x="2220" y="466.67"/>
			<ECTransition Source="Init" Destination="RESET" Condition="[FALSE = Q_INIT]" x="4120" y="266.67"/>
			<ECTransition Source="DeInit" Destination="START" Condition="1" x="2273.33" y="953.33"/>
			<ECTransition Source="RESET" Destination="DeInit" Condition="INIT[FALSE = QI]" x="4160" y="1280"/>
			<ECTransition Source="SET" Destination="DeInit" Condition="INIT[FALSE = QI]" x="4046.67" y="1133.33"/>
			<ECTransition Source="Init" Destination="SET" Condition="[TRUE = Q_INIT]" x="4353.33" y="6.67"/>
		</ECC>
		<Algorithm Name="initialize" Comment="Initialization algorithm">
			<ST><![CDATA[
QO := QI;
]]></ST>
		</Algorithm>
		<Algorithm Name="deInitialize" Comment="Normally executed algorithm">
			<ST><![CDATA[
QO := FALSE;
]]></ST>
		</Algorithm>
		<Algorithm Name="SET" Comment="SET algorithm">
			<ST><![CDATA[
QO := QI;
IF TRUE = QI THEN
	(* only perform normal operation of QI is true *)
	Q.D1 := TRUE;
END_IF;
]]></ST>
		</Algorithm>
		<Algorithm Name="RESET" Comment="RESET algorithm">
			<ST><![CDATA[
QO := QI;
IF TRUE = QI THEN
	(* only perform normal operation of QI is true *)
	Q.D1 := FALSE;
END_IF;
]]></ST>
		</Algorithm>
	</BasicFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
