<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="E_RS_SYM" Comment="Event-driven bistable, symmetric Start-Up Behaviour">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10; &#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0"/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-12" Remarks="initial API and implementation and/or initial documentation"/>
	<CompilerInfo packageName="iec61499::events">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="R" Type="Event" Comment="Reset output Q"/>
			<Event Name="S" Type="Event" Comment="Set output Q"/>
		</EventInputs>
		<EventOutputs>
			<Event Name="EO" Type="Event" Comment="Output Q has changed">
				<With Var="Q"/>
			</Event>
		</EventOutputs>
		<OutputVars>
			<VarDeclaration Name="Q" Type="BOOL" Comment="value of flip flop"/>
		</OutputVars>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="500" y="385"/>
			<ECState Name="SET" x="1200" y="400">
				<ECAction Algorithm="SET" Output="EO"/>
			</ECState>
			<ECState Name="RESET" x="1165" y="845">
				<ECAction Algorithm="RESET" Output="EO"/>
			</ECState>
			<ECTransition Source="START" Destination="SET" Condition="S" x="995" y="455"/>
			<ECTransition Source="SET" Destination="RESET" Condition="R" x="1205" y="685"/>
			<ECTransition Source="RESET" Destination="SET" Condition="S" x="1460" y="675"/>
			<ECTransition Source="START" Destination="RESET" Condition="R" x="906.67" y="833.33"/>
		</ECC>
		<Algorithm Name="SET" Comment="SET algorithm">
			<ST><![CDATA[
Q := TRUE;
]]></ST>
		</Algorithm>
		<Algorithm Name="RESET" Comment="RESET algorithm">
			<ST><![CDATA[
Q := FALSE;
]]></ST>
		</Algorithm>
	</BasicFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
