	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2025-01-24"/>
	<CompilerInfo packageName="adapter::events::unidirectional">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="EI" Type="Event" Comment="Event Input"/>
		</EventInputs>
		<EventOutputs>
			<Event Name="EO0" Type="Event" Comment="Output, switched from EI when G=0"/>
			<Event Name="EO1" Type="Event" Comment="Output, switched from EI when G=1"/>
		</EventOutputs>
		<Sockets>
			<AdapterDeclaration Name="G" Type="adapter::types::unidirectional::AX" Comment="Switch EI to EO0 when G=0, to EO1 when G=1" x="-100" y="300"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_SWITCH" Type="iec61499::events::E_SWITCH" x="820" y="33.33"/>
		<EventConnections>
			<Connection Source="EI" Destination="E_SWITCH.EI" dx1="2620"/>
			<Connection Source="E_SWITCH.EO0" Destination="EO0" dx1="3226.67">
				<Attribute Name="Visible" Value="false"/>
			</Connection>
			<Connection Source="E_SWITCH.EO1" Destination="EO1" dx1="3226.67">
				<Attribute Name="Visible" Value="false"/>
			</Connection>
		</EventConnections>
		<DataConnections>
			<Connection Source="G.D1" Destination="E_SWITCH.G" dx1="73.33"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
