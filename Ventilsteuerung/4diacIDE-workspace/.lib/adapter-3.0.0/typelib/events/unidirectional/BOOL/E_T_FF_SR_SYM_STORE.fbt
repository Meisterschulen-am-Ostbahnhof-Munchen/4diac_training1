<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="E_T_FF_SR_SYM_STORE" Comment="Event-driven bistable and Toggle, symmetric Start-Up Behaviour and INIT">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10; &#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-12" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="iec61499::events">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="S" Type="Event" Comment="Set output Q">
			</Event>
			<Event Name="R" Type="Event" Comment="Reset output Q">
			</Event>
			<Event Name="CLK" Type="Event" Comment="Clock for triggering a output toggle">
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="EO" Type="Event" Comment="Output Q has changed">
				<With Var="Q"/>
			</Event>
		</EventOutputs>
		<OutputVars>
			<VarDeclaration Name="Q" Type="BOOL" Comment="value of flip flop"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="Q_INIT" Type="adapter::types::bidirectional::AX2" Comment="Value of Q at INIT"/>
		</Plugs>
	</InterfaceList>
	<BasicFB>
		<ECC>
			<ECState Name="START" Comment="Initial State" x="1920" y="640">
			</ECState>
			<ECState Name="Init" Comment="Initialization" x="2880" y="480">
				<ECAction/>
			</ECState>
			<ECState Name="SET" x="5233.33" y="1073.33">
				<ECAction Algorithm="SET" Output="EO"/>
				<ECAction Output="Q_INIT.EO1"/>
			</ECState>
			<ECState Name="RESET" x="5200" y="1520">
				<ECAction Algorithm="RESET" Output="EO"/>
				<ECAction Output="Q_INIT.EO1"/>
			</ECState>
			<ECTransition Source="SET" Destination="RESET" Condition="R" x="5240" y="1360"/>
			<ECTransition Source="RESET" Destination="SET" Condition="S" x="5493.33" y="1346.67"/>
			<ECTransition Source="SET" Destination="RESET" Condition="CLK" x="5706.67" y="1340"/>
			<ECTransition Source="RESET" Destination="SET" Condition="CLK" x="4920" y="1366.67"/>
			<ECTransition Source="START" Destination="Init" Condition="Q_INIT.EI1" x="2220" y="466.67"/>
			<ECTransition Source="Init" Destination="RESET" Condition="[FALSE = Q_INIT.DI1]" x="4120" y="266.67"/>
			<ECTransition Source="Init" Destination="SET" Condition="[TRUE = Q_INIT.DI1]" x="4353.33" y="6.67"/>
		</ECC>
		<Algorithm Name="SET" Comment="SET algorithm">
			<ST><![CDATA[
Q := TRUE;
Q_INIT.DO1 := TRUE;
]]></ST>
		</Algorithm>
		<Algorithm Name="RESET" Comment="RESET algorithm">
			<ST><![CDATA[
Q := FALSE;
Q_INIT.DO1 := FALSE;
]]></ST>
		</Algorithm>
	</BasicFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
