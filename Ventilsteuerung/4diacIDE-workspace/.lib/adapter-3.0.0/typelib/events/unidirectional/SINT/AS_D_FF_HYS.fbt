<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AS_D_FF_HYS" Comment="Data latch (d) flip flop with a Hysteresis">
	<Identification Standard="61499-1 Annex A" Description="Copyright (c) 2017 fortiss GmbH, HR Agrartechnik GmbH&#10;&#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-05-15" Remarks="Initial Version">
	</VersionInfo>
	<CompilerInfo packageName="adapter::events::unidirectional">
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Set Hysteresis">
				<With Var="HYSTERESIS"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Init Confirmation">
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="HYSTERESIS" Type="SINT" Comment="Hysteresis band"/>
		</InputVars>
		<Plugs>
			<AdapterDeclaration Name="Q" Type="adapter::types::unidirectional::AS" Comment="Latched value" x="1700" y="-800"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="I" Type="adapter::types::unidirectional::AS" Comment="Value to latch" x="-400" y="-800"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="E_D_FF_ANY_HYS" Type="logiBUS::signalprocessing::hysteresis::E_D_FF_ANY_HYS" x="400" y="-800">
		</FB>
		<EventConnections>
			<Connection Source="I.E1" Destination="E_D_FF_ANY_HYS.CLK"/>
			<Connection Source="E_D_FF_ANY_HYS.EO" Destination="Q.E1"/>
			<Connection Source="INIT" Destination="INITO"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="I.D1" Destination="E_D_FF_ANY_HYS.D"/>
			<Connection Source="E_D_FF_ANY_HYS.Q" Destination="Q.D1"/>
			<Connection Source="HYSTERESIS" Destination="E_D_FF_ANY_HYS.HYSTERESIS" dx1="1266.67"/>
		</DataConnections>
	</FBNetwork>
</FBType>
