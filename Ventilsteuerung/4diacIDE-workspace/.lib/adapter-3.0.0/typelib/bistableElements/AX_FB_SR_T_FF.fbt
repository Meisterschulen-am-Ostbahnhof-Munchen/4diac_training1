<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="AX_FB_SR_T_FF" Comment="Realizes a bistable set-dominat latch plus Toggle (with Adapter)">
	<Identification Standard="61499-1" Description="Copyright (c) 2023 Martin Erich Jobst, HR Agrartechnik GmbH&#10; &#10;This program and the accompanying materials are made&#10;available under the terms of the Eclipse Public License 2.0&#10;which is available at https://www.eclipse.org/legal/epl-2.0/&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Version="3.0" Author="Patrick Aigner" Date="2025-04-14" Remarks="changed package">
	</VersionInfo>
	<VersionInfo Version="1.0" Author="Martin Jobst" Date="2023-04-28" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::bistableElements">
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="Q1" Type="adapter::types::unidirectional::AX" Comment="Output"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="SET1" Type="adapter::types::unidirectional::AX" Comment="Set"/>
			<AdapterDeclaration Name="RESET" Type="adapter::types::unidirectional::AX" Comment="Reset"/>
			<AdapterDeclaration Name="CLK" Type="adapter::types::unidirectional::AX" Comment="Clock"/>
		</Sockets>
	</InterfaceList>
	<BasicFB>
		<InternalVars>
			<VarDeclaration Name="EDGE" Type="BOOL" InitialValue="FALSE"/>
		</InternalVars>
		<ECC>
			<ECState Name="REQ" x="0" y="0">
				<ECAction Algorithm="REQ" Output="Q1.E1"/>
			</ECState>
			<ECTransition Source="REQ" Destination="REQ" Condition="SET1.E1" Comment="" x="-233.33" y="646.67"/>
			<ECTransition Source="REQ" Destination="REQ" Condition="RESET.E1" Comment="" x="380" y="646.67"/>
			<ECTransition Source="REQ" Destination="REQ" Condition="CLK.E1" Comment="" x="73.33" y="646.67"/>
		</ECC>
		<Algorithm Name="REQ">
			<ST><![CDATA[
IF SET1.D1 THEN
	Q1.D1 := BOOL#TRUE;
ELSIF RESET.D1 THEN
	Q1.D1 := BOOL#FALSE;
ELSIF CLK.D1 AND NOT EDGE THEN
	Q1.D1 := NOT Q1.D1;
END_IF;
EDGE := CLK.D1;
]]></ST>
		</Algorithm>
	</BasicFB>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
