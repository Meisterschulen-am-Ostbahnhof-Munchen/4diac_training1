<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ASSEMBLE_AL_FROM_AD" Comment="this Function combines the 2 AD (DWORD) adapters to a AL (LWORD)">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-05-16" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::assembling">
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AL" Comment="LWORD Output" x="3100" y="100"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="DWORD_00" Type="adapter::types::unidirectional::AD" Comment="DWord 0" x="-1200" y="0"/>
			<AdapterDeclaration Name="DWORD_01" Type="adapter::types::unidirectional::AD" Comment="DWord 1" x="-1200" y="1000"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="ASSEMBLE_LWORD_FROM_DWORDS" Type="eclipse4diac::utils::assembling::ASSEMBLE_LWORD_FROM_DWORDS" x="100" y="100">
		</FB>
		<FB Name="E_D_FF_ANY" Type="iec61499::events::E_D_FF_ANY" x="1900" y="100">
		</FB>
		<EventConnections>
			<Connection Source="DWORD_00.E1" Destination="ASSEMBLE_LWORD_FROM_DWORDS.REQ" dx1="420"/>
			<Connection Source="DWORD_01.E1" Destination="ASSEMBLE_LWORD_FROM_DWORDS.REQ" dx1="420"/>
			<Connection Source="ASSEMBLE_LWORD_FROM_DWORDS.CNF" Destination="E_D_FF_ANY.CLK"/>
			<Connection Source="E_D_FF_ANY.EO" Destination="OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="ASSEMBLE_LWORD_FROM_DWORDS." Destination="E_D_FF_ANY.D" dx1="180"/>
			<Connection Source="E_D_FF_ANY.Q" Destination="OUT.D1"/>
			<Connection Source="DWORD_01.D1" Destination="ASSEMBLE_LWORD_FROM_DWORDS.DWORD_01" dx1="320"/>
			<Connection Source="DWORD_00.D1" Destination="ASSEMBLE_LWORD_FROM_DWORDS.DWORD_00" dx1="386.67"/>
		</DataConnections>
	</FBNetwork>
</FBType>
