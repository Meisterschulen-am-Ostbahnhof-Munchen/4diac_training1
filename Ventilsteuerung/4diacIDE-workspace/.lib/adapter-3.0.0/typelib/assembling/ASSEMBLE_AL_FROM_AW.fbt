<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="ASSEMBLE_AL_FROM_AW" Comment="this Function combines the 4 AW (WORD) adapters to a AL (LWORD)">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof&#10;&#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-05-16" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="adapter::assembling">
	</CompilerInfo>
	<InterfaceList>
		<Plugs>
			<AdapterDeclaration Name="OUT" Type="adapter::types::unidirectional::AL" Comment="LWORD Output" x="3100" y="100"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="WORD_00" Type="adapter::types::unidirectional::AW" Comment="Word 0" x="-1200" y="0"/>
			<AdapterDeclaration Name="WORD_01" Type="adapter::types::unidirectional::AW" Comment="Word 1" x="-1200" y="1000"/>
			<AdapterDeclaration Name="WORD_02" Type="adapter::types::unidirectional::AW" Comment="Word 2" x="-1200" y="2000"/>
			<AdapterDeclaration Name="WORD_03" Type="adapter::types::unidirectional::AW" Comment="Word 3" x="-1200" y="3000"/>
		</Sockets>
	</InterfaceList>
	<FBNetwork>
		<FB Name="ASSEMBLE_LWORD_FROM_WORDS" Type="eclipse4diac::utils::assembling::ASSEMBLE_LWORD_FROM_WORDS" x="100" y="100">
		</FB>
		<FB Name="E_D_FF_ANY" Type="iec61499::events::E_D_FF_ANY" x="1900" y="100">
		</FB>
		<EventConnections>
			<Connection Source="WORD_00.E1" Destination="ASSEMBLE_LWORD_FROM_WORDS.REQ" dx1="420"/>
			<Connection Source="WORD_01.E1" Destination="ASSEMBLE_LWORD_FROM_WORDS.REQ" dx1="420"/>
			<Connection Source="WORD_02.E1" Destination="ASSEMBLE_LWORD_FROM_WORDS.REQ" dx1="420"/>
			<Connection Source="WORD_03.E1" Destination="ASSEMBLE_LWORD_FROM_WORDS.REQ" dx1="420"/>
			<Connection Source="ASSEMBLE_LWORD_FROM_WORDS.CNF" Destination="E_D_FF_ANY.CLK"/>
			<Connection Source="E_D_FF_ANY.EO" Destination="OUT.E1"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="ASSEMBLE_LWORD_FROM_WORDS." Destination="E_D_FF_ANY.D" dx1="180"/>
			<Connection Source="E_D_FF_ANY.Q" Destination="OUT.D1"/>
			<Connection Source="WORD_03.D1" Destination="ASSEMBLE_LWORD_FROM_WORDS.WORD_03" dx1="320"/>
			<Connection Source="WORD_02.D1" Destination="ASSEMBLE_LWORD_FROM_WORDS.WORD_02" dx1="353.33"/>
			<Connection Source="WORD_01.D1" Destination="ASSEMBLE_LWORD_FROM_WORDS.WORD_01" dx1="386.67"/>
			<Connection Source="WORD_00.D1" Destination="ASSEMBLE_LWORD_FROM_WORDS.WORD_00" dx1="420"/>
		</DataConnections>
	</FBNetwork>
</FBType>
