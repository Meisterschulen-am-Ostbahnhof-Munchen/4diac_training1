<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="IA_VP1" Comment="ISOBUS Adapter for Vehicle Position 1 (VP1)">
	<Identification Standard="ISO 11783-7" Classification="PGN 65267" Description="Copyright (c) 2024-2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-19" Remarks="initial API and implementation (Adapter Wrapper for I_VP1)">
	</VersionInfo>
	<CompilerInfo packageName="isobus::tecu">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="QI"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
				<With Var="QO"/>
				<With Var="STATUS"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="QI" Type="BOOL" Comment="Event Input Qualifier"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="QO" Type="BOOL" Comment="Event Output Qualifier"/>
			<VarDeclaration Name="STATUS" Type="STRING"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="LAT" Type="adapter::types::unidirectional::AR" Comment="Latitude" x="2900" y="3960"/>
			<AdapterDeclaration Name="LON" Type="adapter::types::unidirectional::AR" Comment="Longitude" x="2900" y="4720"/>
			<AdapterDeclaration Name="TIMEOUT" Type="adapter::types::unidirectional::AX" Comment="Timeout Status" x="3100" y="3400"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="I_CORE" Type="isobus::tecu::I_VP1" x="680" y="3100">
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="I_CORE.INIT" dx1="66.67"/>
			<Connection Source="I_CORE.INITO" Destination="INITO" dx1="66.67"/>
			<Connection Source="I_CORE.IND" Destination="LAT.E1" dx1="266.67"/>
			<Connection Source="I_CORE.IND" Destination="LON.E1" dx1="266.67"/>
			<Connection Source="I_CORE.TIMEOUT" Destination="TIMEOUT.E1" dx1="693.33"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="QI" Destination="I_CORE.QI" dx1="66.67"/>
			<Connection Source="I_CORE.QO" Destination="QO" dx1="333.33"/>
			<Connection Source="I_CORE.STATUS" Destination="STATUS" dx1="400"/>
			<Connection Source="I_CORE.Latitude" Destination="LAT.D1" dx1="133.33"/>
			<Connection Source="I_CORE.Longitude" Destination="LON.D1" dx1="66.67"/>
			<Connection Source="I_CORE.Q_timeout" Destination="TIMEOUT.D1" dx1="200"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
