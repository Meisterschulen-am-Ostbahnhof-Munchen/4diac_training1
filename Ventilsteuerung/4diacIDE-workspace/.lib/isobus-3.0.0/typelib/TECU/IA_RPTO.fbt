<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="IA_RPTO" Comment="ISOBUS Adapter for Rear Power Take off (RPTO)">
	<Identification Standard="ISO 11783-7" Classification="PGN 65091" Description="Copyright (c) 2024-2026 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0"/>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-04-19" Remarks="initial API and implementation (Adapter Wrapper for I_RPTO)"/>
	<CompilerInfo packageName="isobus::tecu">
		<Import declaration="eclipse4diac::core::TypeHash"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="QI"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
				<With Var="QO"/>
				<With Var="STATUS"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="QI" Type="BOOL" Comment="Event Input Qualifier"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="QO" Type="BOOL" Comment="Event Output Qualifier"/>
			<VarDeclaration Name="STATUS" Type="STRING"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="SPEED" Type="adapter::types::unidirectional::AUI" Comment="Rear PTO output shaft speed" x="3600" y="4360"/>
			<AdapterDeclaration Name="SPEED_SET" Type="adapter::types::unidirectional::AUI" Comment="Rear PTO output shaft speed set point" x="3600" y="5120"/>
			<AdapterDeclaration Name="TIMEOUT" Type="adapter::types::unidirectional::AX" Comment="Timeout Status" x="3600" y="3600"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="I_CORE" Type="isobus::tecu::I_RPTO" x="680" y="3100"/>
		<EventConnections>
			<Connection Source="INIT" Destination="I_CORE.INIT" dx1="66.67"/>
			<Connection Source="I_CORE.INITO" Destination="INITO" dx1="66.67"/>
			<Connection Source="I_CORE.IND" Destination="SPEED.E1" dx1="413.33"/>
			<Connection Source="I_CORE.IND" Destination="SPEED_SET.E1" dx1="166.67"/>
			<Connection Source="I_CORE.TIMEOUT" Destination="TIMEOUT.E1" dx1="966.67"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="QI" Destination="I_CORE.QI" dx1="66.67"/>
			<Connection Source="I_CORE.QO" Destination="QO" dx1="333.33"/>
			<Connection Source="I_CORE.STATUS" Destination="STATUS" dx1="400"/>
			<Connection Source="I_CORE.REAR_PTO_OUTP_SHAFT_SPEED" Destination="SPEED.D1" dx1="133.33"/>
			<Connection Source="I_CORE.REAR_PTO_OUTP_SH_SPEED_SET" Destination="SPEED_SET.D1" dx1="66.67"/>
			<Connection Source="I_CORE.Q_timeout" Destination="TIMEOUT.D1" dx1="200"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
