		<EventConnections>
			<Connection Source="INIT" Destination="Q_Attribute.INIT" dx1="1306.67"/>
			<Connection Source="Q_Attribute.INITO" Destination="INITO" dx1="1506.67"/>
			<Connection Source="Q_Attribute.CNF" Destination="CNF" dx1="1760"/>
