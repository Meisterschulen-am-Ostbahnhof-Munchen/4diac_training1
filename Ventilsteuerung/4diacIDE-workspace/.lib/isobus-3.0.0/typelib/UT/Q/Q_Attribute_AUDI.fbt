			<AdapterDeclaration Name="u32OldValueAttribute" Type="adapter::types::unidirectional::AUDI" Comment="Old value for attribute " x="3900" y="1100"/>
		</Plugs>
		<Sockets>
			<AdapterDeclaration Name="u32ValueAttribute" Type="adapter::types::unidirectional::AUDI" Comment="New value for attribute " x="-600" y="1200"/>
		</Sockets>
