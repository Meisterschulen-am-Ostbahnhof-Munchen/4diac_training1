<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="Q_NumericValue_PHYSA_LREAL" Comment="Command change numeric value — accepts physical LREAL value via ALR adapter (wraps Q_NumericValue_PHYS_LREAL)">
	<Identification Standard="ISO 11783-6" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0"/>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-04-21" Remarks="initial API and implementation"/>
	<CompilerInfo packageName="isobus::UT::Q">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="isobus::UT::Q::const::IDs::ID_NULL"/>
		<Import declaration="logiBUS::utils::conversion::phys::NumericObjectPool_S"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="stObj"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm"/>
			<Event Name="CNF" Type="Event" Comment="Confirmation of Requested Service">
				<With Var="STATUS"/>
				<With Var="s16result"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="stObj" Type="logiBUS::utils::conversion::phys::NumericObjectPool_S" Comment="Object pool properties (u16ObjId, scale, offset, decimals)" InitialValue="(u16ObjId := ID_NULL, r32Scale := 1.0, i32Offset := 0, u8Decimals := 0)"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="STATUS" Type="STRING" Comment="Service Status"/>
			<VarDeclaration Name="s16result" Type="INT" Comment="retval see Q_NumericValue"/>
		</OutputVars>
		<Sockets>
			<AdapterDeclaration Name="lrPhys" Type="adapter::types::unidirectional::ALR" Comment="Physical LREAL value input" x="-600" y="1200"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="xOver" Type="adapter::types::unidirectional::AX" Comment="Physical value exceeds upper ISOBUS limit" x="3600" y="1400"/>
			<AdapterDeclaration Name="xUnder" Type="adapter::types::unidirectional::AX" Comment="Physical value below lower ISOBUS limit" x="3500" y="1900"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="Q_NumericValue_PHYS_LREAL" Type="isobus::UT::Q::Q_NumericValue_PHYS_LREAL" x="700" y="500"/>
		<EventConnections>
			<Connection Source="INIT" Destination="Q_NumericValue_PHYS_LREAL.INIT" dx1="1306.67"/>
			<Connection Source="lrPhys.E1" Destination="Q_NumericValue_PHYS_LREAL.REQ" dx1="146.67"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.INITO" Destination="INITO" dx1="1506.67"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.CNF" Destination="CNF" dx1="1760"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.CNF" Destination="xUnder.E1" dx1="673.33"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.CNF" Destination="xOver.E1" dx1="720"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="stObj" Destination="Q_NumericValue_PHYS_LREAL.stObj" dx1="973.33"/>
			<Connection Source="lrPhys.D1" Destination="Q_NumericValue_PHYS_LREAL.lrPhys" dx1="320"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.STATUS" Destination="STATUS" dx1="2000"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.s16result" Destination="s16result" dx1="2573.33"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.xOver" Destination="xOver.D1" dx1="400"/>
			<Connection Source="Q_NumericValue_PHYS_LREAL.xUnder" Destination="xUnder.D1" dx1="160"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
