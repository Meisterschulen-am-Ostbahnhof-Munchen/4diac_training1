<GlobalConstants Name="AID_AM" Comment="Alarm mask object attribute ids">
	<Identification Standard="61499-1" Description="Copyright (c) 2023 HR Agrartechnik GmbH  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="HR Agrartechnik GmbH" Version="1.0" Author="Franz Höpfinger" Date="2026-06-20">
	</VersionInfo>
	<CompilerInfo packageName="isobus::UT::Q::const::AID">
		<Import declaration="eclipse4diac::core::TypeHash" />
	</CompilerInfo>
	<GlobalConstants>
		<VarDeclaration Name="BACKGROUND_COLOUR" Type="USINT" InitialValue="USINT#1" Comment="1: AID_AM_BACKGROUND_COLOUR - Background colour index." />
		<VarDeclaration Name="SOFT_KEY_MASK" Type="USINT" InitialValue="USINT#2" Comment="2: AID_AM_SOFT_KEY_MASK - Object ID of a Soft Key Mask associated with this Alarm Mask." />
		<VarDeclaration Name="ALARM_PRIORITY" Type="USINT" InitialValue="USINT#3" Comment="3: AID_AM_ALARM_PRIORITY - Priority of this alarm: 0 = High (danger/urgent machine malfunction), 1 = Medium (normal alarm, machine malfunctioning), 2 = Low (information only)." />
		<VarDeclaration Name="ACOUSTIC" Type="USINT" InitialValue="USINT#4" Comment="4: AID_AM_ACOUSTIC - Acoustic signal: 0 = highest priority, 1 = medium priority, 2 = lowest priority, 3 = none (silent)." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* alarm mask object attribute ids *)
GLOBALCONSTANTS AID_AM
	VAR_GLOBAL CONSTANT
		BACKGROUND_COLOUR : USINT := USINT#1; (* 1: AID_AM_BACKGROUND_COLOUR - Background colour index. *)
		SOFT_KEY_MASK     : USINT := USINT#2; (* 2: AID_AM_SOFT_KEY_MASK - Object ID of a Soft Key Mask associated with this Alarm Mask. *)
		ALARM_PRIORITY    : USINT := USINT#3; (* 3: AID_AM_ALARM_PRIORITY - Priority of this alarm: 0 = High (danger/urgent machine malfunction), 1 = Medium (normal alarm, machine malfunctioning), 2 = Low (information only). *)
		ACOUSTIC          : USINT := USINT#4; (* 4: AID_AM_ACOUSTIC - Acoustic signal: 0 = highest priority, 1 = medium priority, 2 = lowest priority, 3 = none (silent). *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
</GlobalConstants>
