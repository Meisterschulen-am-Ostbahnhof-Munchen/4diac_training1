	<GlobalConstants>
		<VarDeclaration Name="WIDTH" Type="USINT" InitialValue="USINT#1" Comment="1: AID_OLA_WIDTH - Width in pixels." />
		<VarDeclaration Name="HEIGHT" Type="USINT" InitialValue="USINT#2" Comment="2: AID_OLA_HEIGHT - Height in pixels." />
		<VarDeclaration Name="VARIABLE_REF" Type="USINT" InitialValue="USINT#3" Comment="3: AID_OLA_VARIABLE_REF - Object ID of a Number Variable object." />
		<VarDeclaration Name="VALUE" Type="USINT" InitialValue="USINT#4" Comment="4: AID_OLA_VALUE - Selected list index (0 to 254), or 255 if no item is chosen." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* output list object attribute ids *)
GLOBALCONSTANTS AID_OLA
	VAR_GLOBAL CONSTANT
		WIDTH        : USINT := USINT#1; (* 1: AID_OLA_WIDTH - Width in pixels. *)
		HEIGHT       : USINT := USINT#2; (* 2: AID_OLA_HEIGHT - Height in pixels. *)
		VARIABLE_REF : USINT := USINT#3; (* 3: AID_OLA_VARIABLE_REF - Object ID of a Number Variable object. *)
		VALUE        : USINT := USINT#4; (* 4: AID_OLA_VALUE - Selected list index (0 to 254), or 255 if no item is chosen. *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
