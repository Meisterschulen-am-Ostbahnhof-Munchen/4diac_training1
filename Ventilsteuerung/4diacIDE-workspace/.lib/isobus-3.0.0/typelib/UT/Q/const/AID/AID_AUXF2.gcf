		FUNC              : USINT := USINT#2; (* 2: AID_AUXF2_FUNC - Bitmask: Bits 0-4=Auxiliary function type (0-14), Bit 5=Critical Control, Bit 6=Assignment Restriction, Bit 7=Single-assignment. *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
