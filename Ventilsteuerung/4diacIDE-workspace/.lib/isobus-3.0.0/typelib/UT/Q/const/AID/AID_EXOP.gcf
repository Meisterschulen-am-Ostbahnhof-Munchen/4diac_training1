	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// external object pointer object attribute ids
GLOBALCONSTANTS AID_EXOP
	VAR_GLOBAL CONSTANT
		DEF_OBJ_ID : USINT := USINT#1; // 1: AID_EXOP_DEF_OBJ_ID - Default Object ID to display if external ID is not valid or is the NULL
		                               // Object ID.
		EXT_REF_NAME_ID : USINT := USINT#2; // 2: AID_EXOP_EXT_REF_NAME_ID
		EXT_OBJ : USINT := USINT#3; // 3: AID_EXOP_EXT_OBJ
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
