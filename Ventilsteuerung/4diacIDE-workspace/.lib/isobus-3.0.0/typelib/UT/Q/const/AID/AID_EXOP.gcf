	<GlobalConstants>
		<VarDeclaration Name="DEF_OBJ_ID" Type="USINT" Comment="1: AID_EXOP_DEF_OBJ_ID - Default Object ID to display if external ID is not valid or is the NULL" InitialValue="USINT#1"/>
		<VarDeclaration Name="EXT_REF_NAME_ID" Type="USINT" Comment="2: AID_EXOP_EXT_REF_NAME_ID" InitialValue="USINT#2"/>
