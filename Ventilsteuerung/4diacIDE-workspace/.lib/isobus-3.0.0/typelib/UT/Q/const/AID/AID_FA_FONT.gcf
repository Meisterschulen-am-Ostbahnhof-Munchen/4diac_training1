	<GlobalConstants>
		<VarDeclaration Name="COLOUR" Type="USINT" InitialValue="USINT#1" Comment="1: AID_FA_FONT_COLOUR - Colour index." />
		<VarDeclaration Name="SIZE" Type="USINT" InitialValue="USINT#2" Comment="2: AID_FA_FONT_SIZE" />
		<VarDeclaration Name="FONT_TYPE" Type="USINT" InitialValue="USINT#3" Comment="3: AID_FA_FONT_FONT_TYPE" />
		<VarDeclaration Name="STYLE" Type="USINT" InitialValue="USINT#4" Comment="4: AID_FA_FONT_STYLE - Bitmask: Bit 0=Bold, Bit 1=Crossed Out, Bit 2=Underlined, Bit 3=Italic, Bit 4=Inverted, Bit 5=Flashing inverted, Bit 6=Flashing hidden, Bit 7=Proportional rendering." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* font attributes object attribute ids *)
GLOBALCONSTANTS AID_FA_FONT
	VAR_GLOBAL CONSTANT
		COLOUR    : USINT := USINT#1; (* 1: AID_FA_FONT_COLOUR - Colour index. *)
		SIZE      : USINT := USINT#2; (* 2: AID_FA_FONT_SIZE *)
		FONT_TYPE : USINT := USINT#3; (* 3: AID_FA_FONT_FONT_TYPE *)
		STYLE     : USINT := USINT#4; (* 4: AID_FA_FONT_STYLE - Bitmask: Bit 0=Bold, Bit 1=Crossed Out, Bit 2=Underlined, Bit 3=Italic, Bit 4=Inverted, Bit 5=Flashing inverted, Bit 6=Flashing hidden, Bit 7=Proportional rendering. *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
