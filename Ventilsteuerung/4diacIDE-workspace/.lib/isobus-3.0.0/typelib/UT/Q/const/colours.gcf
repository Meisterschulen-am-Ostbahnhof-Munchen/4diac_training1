	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const;

GLOBALCONSTANTS colours
	VAR_GLOBAL CONSTANT
		// --- 16 ISOBUS/VGA-Standardfarben (0-15) ---
		COLOR_BLACK : USINT := USINT#0; // #000000, rgb(0, 0, 0), black, Schwarz
		COLOR_WHITE : USINT := USINT#1; // #FFFFFF, rgb(255, 255, 255), white, Weiß
		COLOR_GREEN : USINT := USINT#2; // #009900, rgb(0, 153, 0), japanese laurel, Grün
		COLOR_TEAL : USINT := USINT#3; // #009999, rgb(0, 153, 153), persian green, Blaugrün
		COLOR_MAROON : USINT := USINT#4; // #990000, rgb(153, 0, 0), red berry, Kastanienbraun
		COLOR_PURPLE : USINT := USINT#5; // #990099, rgb(153, 0, 153), flirt, Violett
		COLOR_OLIVE : USINT := USINT#6; // #999900, rgb(153, 153, 0), olive, Olivgrün
		COLOR_SILVER : USINT := USINT#7; // #CCCCCC, rgb(204, 204, 204), silver, Silber
		COLOR_GREY : USINT := USINT#8; // #999999, rgb(153, 153, 153), quick silver, Grau
		COLOR_BLUE : USINT := USINT#9; // #0000FF, rgb(0, 0, 255), blue, Blau
		COLOR_LIME : USINT := USINT#10; // #00FF00, rgb(0, 255, 0), lime, Hellgrün
		COLOR_CYAN : USINT := USINT#11; // #00FFFF, rgb(0, 255, 255), cyan / aqua, Türkis
		COLOR_RED : USINT := USINT#12; // #FF0000, rgb(255, 0, 0), red, Rot
		COLOR_MAGENTA : USINT := USINT#13; // #FF00FF, rgb(255, 0, 255), magenta / fuchsia, Magenta
		COLOR_YELLOW : USINT := USINT#14; // #FFFF00, rgb(255, 255, 0), yellow, Gelb
		COLOR_NAVY : USINT := USINT#15; // #000099, rgb(0, 0, 153), blue gray, Marineblau

		// --- Websafe 6x6x6 Farben (16-231), exakt berechnet für ISOBUS ---
		// 🔴 Rottöne & Pink
		COLOR_WS_RED : USINT := USINT#196; // #FF0000, rgb(255, 0, 0), Red, Rot
		COLOR_WS_DARK_RED : USINT := USINT#160; // #CC0000, rgb(204, 0, 0), Dark Red, Dunkelrot
		COLOR_WS_DEEP_RED : USINT := USINT#124; // #990000, rgb(153, 0, 0), Deep Red, Tiefrot
		COLOR_WS_VERY_DARK_RED : USINT := USINT#52; // #330000, rgb(51, 0, 0), Very Dark Red, Sehr dunkles Rot
		COLOR_WS_MAGENTA : USINT := USINT#201; // #FF00FF, rgb(255, 0, 255), Magenta / Fuchsia, Magenta / Pink
		COLOR_WS_PINK : USINT := USINT#218; // #FF99CC, rgb(255, 153, 204), Pink, Rosa
		COLOR_WS_LIGHT_PINK : USINT := USINT#224; // #FFCCCC, rgb(255, 204, 204), Light Pink, Hellrosa

		// 🟢 Grüntöne
		COLOR_WS_LIME : USINT := USINT#46; // #00FF00, rgb(0, 255, 0), Lime, Helles Grün / Limette
		COLOR_WS_GREEN : USINT := USINT#40; // #00CC00, rgb(0, 204, 0), Green, Sattes Grün
		COLOR_WS_DARK_GREEN : USINT := USINT#28; // #006600, rgb(0, 102, 0), Dark Green, Dunkelgrün
		COLOR_WS_VERY_DARK_GREEN : USINT := USINT#22; // #003300, rgb(0, 51, 0), Very Dark Green, Waldgrün
		COLOR_WS_SEA_GREEN : USINT := USINT#71; // #339933, rgb(51, 153, 51), Sea Green, Seegrün
		COLOR_WS_YELLOW_GREEN : USINT := USINT#106; // #669900, rgb(102, 153, 0), Yellow Green, Gelbgrün / Oliv
		COLOR_WS_PALE_GREEN : USINT := USINT#194; // #CCFFCC, rgb(204, 255, 204), Pale Green, Blassgrün

		// 🔵 Blautöne & Türkis
		COLOR_WS_BLUE : USINT := USINT#21; // #0000FF, rgb(0, 0, 255), Blue, Blau
		COLOR_WS_MEDIUM_BLUE : USINT := USINT#19; // #000099, rgb(0, 0, 153), Medium Blue, Mittelblau
		COLOR_WS_DARK_BLUE : USINT := USINT#18; // #000066, rgb(0, 0, 102), Dark Blue, Dunkelblau
		COLOR_WS_NAVY_BLUE : USINT := USINT#17; // #000033, rgb(0, 0, 51), Navy Blue, Marineblau
		COLOR_WS_CYAN : USINT := USINT#51; // #00FFFF, rgb(0, 255, 255), Cyan / Aqua, Türkis / Cyan
		COLOR_WS_DEEP_SKY_BLUE : USINT := USINT#45; // #00CCFF, rgb(0, 204, 255), Deep Sky Blue, Kräftiges Himmelblau
		COLOR_WS_LIGHT_BLUE : USINT := USINT#153; // #99CCFF, rgb(153, 204, 255), Light Blue, Hellblau

		// 🟡 Gelb & Orange
		COLOR_WS_YELLOW : USINT := USINT#226; // #FFFF00, rgb(255, 255, 0), Yellow, Gelb
		COLOR_WS_GOLD : USINT := USINT#220; // #FFCC00, rgb(255, 204, 0), Gold, Goldgelb
		COLOR_WS_ORANGE : USINT := USINT#214; // #FF9900, rgb(255, 153, 0), Orange, Orange
		COLOR_WS_DARK_ORANGE : USINT := USINT#208; // #FF6600, rgb(255, 102, 0), Dark Orange, Dunkelorange
		COLOR_WS_LIGHT_YELLOW : USINT := USINT#230; // #FFFFCC, rgb(255, 255, 204), Light Yellow, Hellgelb / Creme

		// 🟤 Braun & Violett
		COLOR_WS_LIGHT_BROWN : USINT := USINT#137; // #996633, rgb(153, 102, 51), Light Brown, Hellbraun
		COLOR_WS_BROWN : USINT := USINT#94; // #663300, rgb(102, 51, 0), Brown, Braun
		COLOR_WS_PURPLE : USINT := USINT#127; // #990099, rgb(153, 0, 153), Purple, Violett
		COLOR_WS_DARK_PURPLE : USINT := USINT#90; // #660066, rgb(102, 0, 102), Dark Purple, Dunkelviolett
		COLOR_WS_VERY_DARK_PURPLE : USINT := USINT#53; // #330033, rgb(51, 0, 51), Very Dark Purple, Tiefviolett

		// ⚪ Graustufen
		COLOR_WS_BLACK : USINT := USINT#16; // #000000, rgb(0, 0, 0), Black, Schwarz (Doppelt als Websafe)
		COLOR_WS_DARK_SLATE_GRAY : USINT := USINT#59; // #333333, rgb(51, 51, 51), Dark Slate Gray, Dunkelgrau
		COLOR_WS_DIM_GRAY : USINT := USINT#102; // #666666, rgb(102, 102, 102), Dim Gray, Grau
		COLOR_WS_GRAY : USINT := USINT#145; // #999999, rgb(153, 153, 153), Gray, Mittelgrau
		COLOR_WS_LIGHT_GRAY : USINT := USINT#188; // #CCCCCC, rgb(204, 204, 204), Light Gray, Hellgrau
		COLOR_WS_WHITE : USINT := USINT#231; // #FFFFFF, rgb(255, 255, 255), White, Weiß (Doppelt als Websafe)

	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
</GlobalConstants>
