	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// output rectangle object attribute ids 
GLOBALCONSTANTS AID_OR
	VAR_GLOBAL CONSTANT
		LINE_ATT   : USINT := USINT#1; // 1: AID_OR_LINE_ATT - Object ID of a Line Attributes object. 
		WIDTH      : USINT := USINT#2; // 2: AID_OR_WIDTH - Width in pixels. 
		HEIGHT     : USINT := USINT#3; // 3: AID_OR_HEIGHT - Height in pixels. 
		LINE_SUPPR : USINT := USINT#4; // 4: AID_OR_LINE_SUPPR 
		FILL_ATT   : USINT := USINT#5; // 5: AID_OR_FILL_ATT - Object ID of a Fill Attributes object. 
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
