	<GlobalConstants>
		<VarDeclaration Name="LINE_ATT" Type="USINT" InitialValue="USINT#1" Comment="1: AID_OR_LINE_ATT - Object ID of a Line Attributes object." />
		<VarDeclaration Name="WIDTH" Type="USINT" InitialValue="USINT#2" Comment="2: AID_OR_WIDTH - Width in pixels." />
		<VarDeclaration Name="HEIGHT" Type="USINT" InitialValue="USINT#3" Comment="3: AID_OR_HEIGHT - Height in pixels." />
