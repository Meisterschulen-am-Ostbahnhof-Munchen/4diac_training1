	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// external reference name object attribute ids
GLOBALCONSTANTS AID_EXRN
	VAR_GLOBAL CONSTANT
		OPTIONS : USINT := USINT#1; // 1: AID_EXRN_OPTIONS - Bitmask: Bit 0 = Enabled (allows external reference by NAME WS).
		NAME_0 : USINT := USINT#2; // 2: AID_EXRN_NAME_0
		NAME_1 : USINT := USINT#3; // 3: AID_EXRN_NAME_1
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
