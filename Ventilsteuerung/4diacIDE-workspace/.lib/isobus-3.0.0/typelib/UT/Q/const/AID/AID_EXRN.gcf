	<GlobalConstants>
		<VarDeclaration Name="OPTIONS" Type="USINT" Comment="1: AID_EXRN_OPTIONS - Bitmask: Bit 0 = Enabled (allows external reference by NAME WS)." InitialValue="USINT#1"/>
		<VarDeclaration Name="NAME_0" Type="USINT" Comment="2: AID_EXRN_NAME_0" InitialValue="USINT#2"/>
		<VarDeclaration Name="NAME_1" Type="USINT" Comment="3: AID_EXRN_NAME_1" InitialValue="USINT#3"/>
