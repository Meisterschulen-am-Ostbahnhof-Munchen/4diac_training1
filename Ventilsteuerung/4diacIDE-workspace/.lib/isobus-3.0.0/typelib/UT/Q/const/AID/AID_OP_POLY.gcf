	<CompilerInfo packageName="isobus::UT::Q::const::AID">
		<Import declaration="eclipse4diac::core::TypeHash" />
	</CompilerInfo>
	<GlobalConstants>
		<VarDeclaration Name="WIDTH" Type="USINT" InitialValue="USINT#1" Comment="1: AID_OP_POLY_WIDTH - Width in pixels." />
		<VarDeclaration Name="HEIGHT" Type="USINT" InitialValue="USINT#2" Comment="2: AID_OP_POLY_HEIGHT - Height in pixels." />
		<VarDeclaration Name="LINE_ATT" Type="USINT" InitialValue="USINT#3" Comment="3: AID_OP_POLY_LINE_ATT - Object ID of a Line Attributes object." />
		<VarDeclaration Name="FILL_ATT" Type="USINT" InitialValue="USINT#4" Comment="4: AID_OP_POLY_FILL_ATT - Object ID of a Fill Attributes object." />
		<VarDeclaration Name="POLYGON_TYPE" Type="USINT" InitialValue="USINT#5" Comment="5: AID_OP_POLY_POLYGON_TYPE - Polygon type: 0=Convex, 1=Non-Convex, 2=Complex, 3=Open." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* output polygon object attribute ids *)
GLOBALCONSTANTS AID_OP_POLY
	VAR_GLOBAL CONSTANT
		WIDTH        : USINT := USINT#1; (* 1: AID_OP_POLY_WIDTH - Width in pixels. *)
		HEIGHT       : USINT := USINT#2; (* 2: AID_OP_POLY_HEIGHT - Height in pixels. *)
		LINE_ATT     : USINT := USINT#3; (* 3: AID_OP_POLY_LINE_ATT - Object ID of a Line Attributes object. *)
		FILL_ATT     : USINT := USINT#4; (* 4: AID_OP_POLY_FILL_ATT - Object ID of a Fill Attributes object. *)
		POLYGON_TYPE : USINT := USINT#5; (* 5: AID_OP_POLY_POLYGON_TYPE - Polygon type: 0=Convex, 1=Non-Convex, 2=Complex, 3=Open. *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
</GlobalConstants>
