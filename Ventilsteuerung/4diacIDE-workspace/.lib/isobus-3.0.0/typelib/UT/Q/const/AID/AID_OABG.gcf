	<GlobalConstants>
		<VarDeclaration Name="WIDTH" Type="USINT" InitialValue="USINT#1" Comment="1: AID_OABG_WIDTH - Width in pixels." />
		<VarDeclaration Name="HEIGHT" Type="USINT" InitialValue="USINT#2" Comment="2: AID_OABG_HEIGHT - Height in pixels." />
		<VarDeclaration Name="COLOUR" Type="USINT" InitialValue="USINT#3" Comment="3: AID_OABG_COLOUR - Colour index." />
		<VarDeclaration Name="TARGET_LINE_COLOUR" Type="USINT" InitialValue="USINT#4" Comment="4: AID_OABG_TARGET_LINE_COLOUR" />
		<VarDeclaration Name="OPTIONS" Type="USINT" InitialValue="USINT#5" Comment="5: AID_OABG_OPTIONS - Bitmask: Bit 0=Draw border, Bit 1=Draw target line, Bit 2=Undefined (set to 0), Bit 3=Bar graph type (0=filled, 1=single line), Bit 4=Deflection (0=anticlockwise, 1=clockwise)." />
		<VarDeclaration Name="START_ANGLE" Type="USINT" InitialValue="USINT#6" Comment="6: AID_OABG_START_ANGLE" />
		<VarDeclaration Name="END_ANGLE" Type="USINT" InitialValue="USINT#7" Comment="7: AID_OABG_END_ANGLE" />
		<VarDeclaration Name="BAR_GRAPH_WIDTH" Type="USINT" InitialValue="USINT#8" Comment="8: AID_OABG_BAR_GRAPH_WIDTH" />
