	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* output arched bar graph object attribute ids *)
GLOBALCONSTANTS AID_OABG
	VAR_GLOBAL CONSTANT
		WIDTH              : USINT := USINT#1; (* 1: AID_OABG_WIDTH - Width in pixels. *)
		HEIGHT             : USINT := USINT#2; (* 2: AID_OABG_HEIGHT - Height in pixels. *)
		COLOUR             : USINT := USINT#3; (* 3: AID_OABG_COLOUR - Colour index. *)
		TARGET_LINE_COLOUR : USINT := USINT#4; (* 4: AID_OABG_TARGET_LINE_COLOUR *)
		OPTIONS            : USINT := USINT#5; (* 5: AID_OABG_OPTIONS - Bitmask: Bit 0=Draw border, Bit 1=Draw target line, Bit 2=Undefined (set to 0), Bit 3=Bar graph type (0=filled, 1=single line), Bit 4=Deflection (0=anticlockwise, 1=clockwise). *)
		START_ANGLE        : USINT := USINT#6; (* 6: AID_OABG_START_ANGLE *)
		END_ANGLE          : USINT := USINT#7; (* 7: AID_OABG_END_ANGLE *)
		BAR_GRAPH_WIDTH    : USINT := USINT#8; (* 8: AID_OABG_BAR_GRAPH_WIDTH *)
		MIN_VALUE          : USINT := USINT#9; (* 9: AID_OABG_MIN_VALUE *)
		MAX_VALUE          : USINT := USINT#10; (* 10: AID_OABG_MAX_VALUE *)
		VARIABLE_REF       : USINT := USINT#11; (* 11: AID_OABG_VARIABLE_REF - Object ID of a Variable object. *)
		TARGET_VAL_VAR_REF : USINT := USINT#12; (* 12: AID_OABG_TARGET_VAL_VAR_REF *)
		TARGET_VALUE       : USINT := USINT#13; (* 13: AID_OABG_TARGET_VALUE *)
		VALUE              : USINT := USINT#14; (* 14: AID_OABG_VALUE - Current value. *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
</GlobalConstants>
