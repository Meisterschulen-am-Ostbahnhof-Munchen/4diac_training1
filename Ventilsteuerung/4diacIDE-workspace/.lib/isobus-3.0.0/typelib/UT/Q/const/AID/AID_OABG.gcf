		<VarDeclaration Name="MAX_VALUE" Type="USINT" InitialValue="USINT#10" Comment="10: AID_OABG_MAX_VALUE" />
		<VarDeclaration Name="VARIABLE_REF" Type="USINT" InitialValue="USINT#11" Comment="11: AID_OABG_VARIABLE_REF - Object ID of a Variable object." />
		<VarDeclaration Name="TARGET_VAL_VAR_REF" Type="USINT" InitialValue="USINT#12" Comment="12: AID_OABG_TARGET_VAL_VAR_REF" />
