	</VersionInfo>
	<CompilerInfo packageName="isobus::UT::Q::const::AID">
		<Import declaration="eclipse4diac::core::TypeHash" />
	</CompilerInfo>
	<GlobalConstants>
		<VarDeclaration Name="WIDTH" Type="USINT" InitialValue="USINT#1" Comment="1: AID_IL_WIDTH - Width in pixels." />
		<VarDeclaration Name="HEIGHT" Type="USINT" InitialValue="USINT#2" Comment="2: AID_IL_HEIGHT - Height in pixels." />
		<VarDeclaration Name="VARIABLE_REF" Type="USINT" InitialValue="USINT#3" Comment="3: AID_IL_VARIABLE_REF - Object ID of a Number Variable object." />
		<VarDeclaration Name="VALUE" Type="USINT" InitialValue="USINT#4" Comment="4: AID_IL_VALUE - Selected list index (0 to 254), or 255 if no item is chosen." />
		<VarDeclaration Name="OPTIONS" Type="USINT" InitialValue="USINT#5" Comment="5: AID_IL_OPTIONS - Bitmask: Bit 0=Enabled, Bit 1=Real-time editing." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// input list object attribute ids 
GLOBALCONSTANTS AID_IL
	VAR_GLOBAL CONSTANT
		WIDTH        : USINT := USINT#1; // 1: AID_IL_WIDTH - Width in pixels. 
		HEIGHT       : USINT := USINT#2; // 2: AID_IL_HEIGHT - Height in pixels. 
		VARIABLE_REF : USINT := USINT#3; // 3: AID_IL_VARIABLE_REF - Object ID of a Number Variable object. 
		VALUE        : USINT := USINT#4; // 4: AID_IL_VALUE - Selected list index (0 to 254), or 255 if no item is chosen. 
		OPTIONS      : USINT := USINT#5; // 5: AID_IL_OPTIONS - Bitmask: Bit 0=Enabled, Bit 1=Real-time editing. 
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
</GlobalConstants>
