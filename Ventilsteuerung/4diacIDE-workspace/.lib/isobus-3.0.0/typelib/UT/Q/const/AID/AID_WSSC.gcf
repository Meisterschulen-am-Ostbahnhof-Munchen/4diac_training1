	<GlobalConstants>
		<VarDeclaration Name="NUMOFBYTES" Type="USINT" InitialValue="USINT#1" Comment="1: AID_WSSC_NUMOFBYTES - Number of bytes to follow in this object." />
		<VarDeclaration Name="COLOUR_MAP" Type="USINT" InitialValue="USINT#2" Comment="2: AID_WSSC_COLOUR_MAP - Object ID of a Colour Map object, or NULL." />
