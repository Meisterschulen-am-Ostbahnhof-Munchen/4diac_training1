	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// working set special controls object attribute ids 
GLOBALCONSTANTS AID_WSSC
	VAR_GLOBAL CONSTANT
		NUMOFBYTES     : USINT := USINT#1; // 1: AID_WSSC_NUMOFBYTES - Number of bytes to follow in this object. 
		COLOUR_MAP     : USINT := USINT#2; // 2: AID_WSSC_COLOUR_MAP - Object ID of a Colour Map object, or NULL. 
		COLOUR_PALETTE : USINT := USINT#3; // 3: AID_WSSC_COLOUR_PALETTE - Object ID of a Colour Palette object, or NULL. 
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
