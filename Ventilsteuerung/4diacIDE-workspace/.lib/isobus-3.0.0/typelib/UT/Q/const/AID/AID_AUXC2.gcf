	<GlobalConstants>
		<VarDeclaration Name="PTR_TYPE" Type="USINT" InitialValue="USINT#1" Comment="1: AID_AUXC2_PTR_TYPE - Pointer Type: 0=Points to Aux Object, 1=Points to Aux Function/Input assigned to Aux Object, 2=Points to Working Set owner of pointer, 3=Points to Working Set owner of assigned function/input." />
		<VarDeclaration Name="OBJ_ID" Type="USINT" InitialValue="USINT#2" Comment="2: AID_AUXC2_OBJ_ID - Object ID of a referenced Auxiliary Function or Auxiliary Input object or NULL." />
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

// auxiliary control designator type 2 object attribute ids 
GLOBALCONSTANTS AID_AUXC2
	VAR_GLOBAL CONSTANT
		PTR_TYPE : USINT := USINT#1; // 1: AID_AUXC2_PTR_TYPE - Pointer Type: 0=Points to Aux Object, 1=Points to Aux Function/Input assigned to Aux Object, 2=Points to Working Set owner of pointer, 3=Points to Working Set owner of assigned function/input. 
		OBJ_ID   : USINT := USINT#2; // 2: AID_AUXC2_OBJ_ID - Object ID of a referenced Auxiliary Function or Auxiliary Input object or NULL. 
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
