	<OriginalSource><![CDATA[PACKAGE isobus::UT::Q::const::AID;

(* external object attribute ids *)
GLOBALCONSTANTS AID_EX
	VAR_GLOBAL CONSTANT
		OPTIONS : USINT := USINT#1; (* 1: AID_EX_OPTIONS - Bitmask: Bit 0 = Enabled (allows referenced NAME WS to reference listed objects). *)
		NAME_0  : USINT := USINT#2; (* 2: AID_EX_NAME_0 *)
		NAME_1  : USINT := USINT#3; (* 3: AID_EX_NAME_1 *)
	END_VAR
END_GLOBALCONSTANTS
]]></OriginalSource>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''" />
