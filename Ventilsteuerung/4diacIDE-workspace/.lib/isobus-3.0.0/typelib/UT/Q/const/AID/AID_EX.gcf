	<GlobalConstants>
		<VarDeclaration Name="OPTIONS" Type="USINT" InitialValue="USINT#1" Comment="1: AID_EX_OPTIONS - Bitmask: Bit 0 = Enabled (allows referenced NAME WS to reference listed objects)." />
		<VarDeclaration Name="NAME_0" Type="USINT" InitialValue="USINT#2" Comment="2: AID_EX_NAME_0" />
		<VarDeclaration Name="NAME_1" Type="USINT" InitialValue="USINT#3" Comment="3: AID_EX_NAME_1" />
