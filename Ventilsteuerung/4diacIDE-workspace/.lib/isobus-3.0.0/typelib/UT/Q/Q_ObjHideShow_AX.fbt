	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-04-24" Remarks="AX adapter wrapper for Q_ObjHideShow">
	</VersionInfo>
	<CompilerInfo packageName="isobus::UT::Q">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="adapter::types::unidirectional::AX"/>
		<Import declaration="isobus::UT::Q::Q_ObjHideShow"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="u16ObjId"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="u16ObjId" Type="UINT" Comment="Object ID"/>
		</InputVars>
		<Sockets>
			<AdapterDeclaration Name="REQ" Type="adapter::types::unidirectional::AX" Comment="Hide/Show request (BOOL)"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="CNF" Type="adapter::types::unidirectional::AX" Comment="Confirmation"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="Q_ObjHideShow" Type="isobus::UT::Q::Q_ObjHideShow" x="0" y="0">
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="Q_ObjHideShow.INIT" dx1="200"/>
			<Connection Source="Q_ObjHideShow.INITO" Destination="INITO" dx1="200"/>
			<Connection Source="REQ.E1" Destination="Q_ObjHideShow.REQ" dx1="200"/>
			<Connection Source="Q_ObjHideShow.CNF" Destination="CNF.E1" dx1="200"/>
		</EventConnections>
		<DataConnections>
