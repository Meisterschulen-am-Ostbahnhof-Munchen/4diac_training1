	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-04-24" Remarks="AX adapter wrapper for Q_ObjHideShow"/>
	<CompilerInfo packageName="isobus::UT::Q">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="adapter::types::unidirectional::AX"/>
		<Import declaration="isobus::UT::Q::Q_ObjHideShow"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="u16ObjId"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm"/>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="u16ObjId" Type="UINT" Comment="Object ID"/>
		</InputVars>
		<Sockets>
			<AdapterDeclaration Name="qVisible" Type="adapter::types::unidirectional::AX" Comment="0 == hidden, 1 == shown" x="-1200" y="-100"/>
		</Sockets>
		<Plugs>
			<AdapterDeclaration Name="qOldVisible" Type="adapter::types::unidirectional::AB" Comment="Old value of Visible 0 == hidden, 1 == shown, 0xFF == undefined" x="2900" y="-300"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="Q_ObjHideShow" Type="isobus::UT::Q::Q_ObjHideShow" x="800" y="-700"/>
		<EventConnections>
			<Connection Source="INIT" Destination="Q_ObjHideShow.INIT" dx1="1220"/>
			<Connection Source="Q_ObjHideShow.INITO" Destination="INITO" dx1="200"/>
			<Connection Source="qVisible.E1" Destination="Q_ObjHideShow.REQ" dx1="606.67"/>
			<Connection Source="Q_ObjHideShow.CNF" Destination="qOldVisible.E1" dx1="586.67"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="u16ObjId" Destination="Q_ObjHideShow.u16ObjId" dx1="200"/>
			<Connection Source="qVisible.D1" Destination="Q_ObjHideShow.qVisible" dx1="1000"/>
			<Connection Source="Q_ObjHideShow.qOldVisible" Destination="qOldVisible.D1" dx1="533.33"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
