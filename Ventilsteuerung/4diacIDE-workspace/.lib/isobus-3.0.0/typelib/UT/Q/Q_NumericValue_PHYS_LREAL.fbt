<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="Q_NumericValue_PHYS_LREAL" Comment="Command change numeric value — accepts NumericObjectPool_S struct and LREAL ( Part 6 - F.22 )">
	<Identification Standard="ISO 11783-6" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-04-21" Remarks="initial API and implementation">
	</VersionInfo>
	<CompilerInfo packageName="isobus::UT::Q">
		<Import declaration="eclipse4diac::core::TypeHash"/>
		<Import declaration="isobus::UT::Q::const::IDs::ID_NULL"/>
		<Import declaration="logiBUS::utils::conversion::phys::NumericObjectPool_S"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="stObj"/>
			</Event>
			<Event Name="REQ" Type="Event" Comment="Service Request">
				<With Var="lrPhys"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
			</Event>
			<Event Name="CNF" Type="Event" Comment="Confirmation of Requested Service">
				<With Var="STATUS"/>
				<With Var="u32OldValue"/>
				<With Var="s16result"/>
				<With Var="xOver"/>
				<With Var="xUnder"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="stObj" Type="logiBUS::utils::conversion::phys::NumericObjectPool_S" Comment="Object pool properties (u16ObjId, scale, offset, decimals)" InitialValue="(u16ObjId := ID_NULL, r32Scale := 1.0, i32Offset := 0, u8Decimals := 0)"/>
			<VarDeclaration Name="lrPhys" Type="LREAL" Comment="New raw value — use F_PHYS_LREAL_TO_RAW to convert from physical value"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="STATUS" Type="STRING" Comment="Service Status"/>
			<VarDeclaration Name="u32OldValue" Type="UDINT" Comment="Old raw value of ID"/>
			<VarDeclaration Name="s16result" Type="INT" Comment="retval see Q_NumericValue"/>
			<VarDeclaration Name="xOver" Type="BOOL" Comment="Physical value exceeds upper ISOBUS limit"/>
			<VarDeclaration Name="xUnder" Type="BOOL" Comment="Physical value below lower ISOBUS limit"/>
		</OutputVars>
	</InterfaceList>
	<FBNetwork>
		<FB Name="Q_NumericValue" Type="isobus::UT::Q::Q_NumericValue" x="700" y="500">
		</FB>
		<FB Name="F_PHYS_LREAL_TO_RAW" Type="logiBUS::utils::conversion::phys::F_PHYS_LREAL_TO_RAW" x="-1100" y="1300">
		</FB>
		<FB Name="F_MOVE" Type="iec61131::selection::F_MOVE" x="-2500" y="300">
			<Attribute Name="DataType" Value="logiBUS::utils::conversion::phys::NumericObjectPool_S"/>
			<Parameter Name="OUT.u16ObjId" Value="">
				<Attribute Name="Visible" Value="true"/>
			</Parameter>
		</FB>
		<EventConnections>
			<Connection Source="Q_NumericValue.INITO" Destination="INITO" dx1="1506.67"/>
			<Connection Source="Q_NumericValue.CNF" Destination="CNF" dx1="1760"/>
			<Connection Source="F_PHYS_LREAL_TO_RAW.CNF" Destination="Q_NumericValue.REQ" dx1="106.67"/>
			<Connection Source="INIT" Destination="F_MOVE.REQ" dx1="1513.33"/>
			<Connection Source="REQ" Destination="F_PHYS_LREAL_TO_RAW.REQ" dx1="1306.67"/>
			<Connection Source="F_MOVE.CNF" Destination="Q_NumericValue.INIT" dx1="953.33"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="Q_NumericValue.STATUS" Destination="STATUS" dx1="2000"/>
			<Connection Source="Q_NumericValue.u32OldValue" Destination="u32OldValue" dx1="2166.67"/>
			<Connection Source="Q_NumericValue.s16result" Destination="s16result" dx1="2573.33"/>
			<Connection Source="stObj" Destination="F_PHYS_LREAL_TO_RAW.stObj" dx1="713.33"/>
			<Connection Source="F_PHYS_LREAL_TO_RAW." Destination="Q_NumericValue.u32NewValue" dx1="320"/>
			<Connection Source="lrPhys" Destination="F_PHYS_LREAL_TO_RAW.lrPhys" dx1="593.33"/>
			<Connection Source="stObj" Destination="F_MOVE.IN" dx1="1100"/>
			<Connection Source="F_MOVE.OUT.u16ObjId" Destination="Q_NumericValue.u16ObjId" dx1="533.33"/>
			<Connection Source="F_PHYS_LREAL_TO_RAW.xOver" Destination="xOver" dx1="4460"/>
			<Connection Source="F_PHYS_LREAL_TO_RAW.xUnder" Destination="xUnder" dx1="4573.33"/>
		</DataConnections>
	</FBNetwork>
	<Attribute Name="eclipse4diac::core::TypeHash" Value="''"/>
</FBType>
