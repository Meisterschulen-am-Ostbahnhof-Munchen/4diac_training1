<?xml version="1.0" encoding="UTF-8"?>
<Function Name="F_PHYS_TO_RAW" Comment="Convert physical REAL value to ISOBUS raw UDINT.&#10;ISOBUS formula: display = (raw + offset) * scale Inverse:        raw     = UDINT(DINT(phys /&#10;scale) - offset)&#10;&#10;Example: phys=-500.0, scale=0.01, offset=-100000 DINT(-500.0 / 0.01) = -50000&#10;-50000 - (-100000)  = 50000 UDINT(50000)        = 50000  -&gt; UT displays (50000 + (-100000))&#10;0.01 = -500.00">
	<Identification Standard="61499-2" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
