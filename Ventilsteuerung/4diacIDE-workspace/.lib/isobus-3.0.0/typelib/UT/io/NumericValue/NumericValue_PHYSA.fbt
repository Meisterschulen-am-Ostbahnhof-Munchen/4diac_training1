<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="NumericValue_PHYSA" Comment="Input service interface function block — outputs physical REAL value via AR adapter (wraps NumericValue_PHYS)">
	<Identification Standard="ISO 11783-6" Description="Copyright (c) 2026 Meisterschulen am Ostbahnhof  &#10; &#10;This program and the accompanying materials are made  &#10;available under the terms of the Eclipse Public License 2.0  &#10;which is available at https://www.eclipse.org/legal/epl-2.0/  &#10; &#10;SPDX-License-Identifier: EPL-2.0">
	</Identification>
	<VersionInfo Organization="Meisterschulen am Ostbahnhof" Version="1.0" Author="Franz Höpfinger" Date="2026-04-14" Remarks="initial API and implementation and/or initial documentation">
	</VersionInfo>
	<CompilerInfo packageName="isobus::UT::io::NumericValue">
		<Import declaration="logiBUS::utils::conversion::phys::NumericObjectPool_S"/>
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Service Initialization">
				<With Var="QI"/>
				<With Var="PARAMS"/>
				<With Var="stObj"/>
			</Event>
			<Event Name="REQ" Type="Event" Comment="Service Request">
				<With Var="QI"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
				<With Var="QO"/>
				<With Var="STATUS"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="QI" Type="BOOL" Comment="Event Input Qualifier"/>
			<VarDeclaration Name="PARAMS" Type="STRING" Comment="Service Parameters"/>
			<VarDeclaration Name="stObj" Type="logiBUS::utils::conversion::phys::NumericObjectPool_S" Comment="Object pool properties (u16ObjId, scale, offset, decimals)"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="QO" Type="BOOL" Comment="Event Output Qualifier"/>
			<VarDeclaration Name="STATUS" Type="STRING" Comment="Service Status"/>
		</OutputVars>
		<Plugs>
			<AdapterDeclaration Name="rPhys" Type="adapter::types::unidirectional::AR" Comment="Physical REAL value output" x="2800" y="1300"/>
		</Plugs>
	</InterfaceList>
	<FBNetwork>
		<FB Name="NumericValue_PHYS" Type="isobus::UT::io::NumericValue::NumericValue_PHYS" x="426.67" y="553.33">
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="NumericValue_PHYS.INIT" dx1="1320"/>
			<Connection Source="REQ" Destination="NumericValue_PHYS.REQ" dx1="1040"/>
			<Connection Source="NumericValue_PHYS.INITO" Destination="INITO" dx1="1273.33"/>
			<Connection Source="NumericValue_PHYS.IND" Destination="rPhys.E1" dx1="693.33"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="stObj" Destination="NumericValue_PHYS.stObj" dx1="80"/>
			<Connection Source="PARAMS" Destination="NumericValue_PHYS.PARAMS" dx1="180"/>
			<Connection Source="QI" Destination="NumericValue_PHYS.QI" dx1="700"/>
			<Connection Source="NumericValue_PHYS.QO" Destination="QO" dx1="1480"/>
			<Connection Source="NumericValue_PHYS.STATUS" Destination="STATUS" dx1="1766.67"/>
			<Connection Source="NumericValue_PHYS.rPhys" Destination="rPhys.D1" dx1="206.67"/>
		</DataConnections>
	</FBNetwork>
</FBType>
