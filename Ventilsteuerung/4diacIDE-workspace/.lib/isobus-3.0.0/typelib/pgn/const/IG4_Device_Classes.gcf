<GlobalConstants Name="IG4_Device_Classes" Comment="Industry Group 4 specific device classes (vehicle systems)">
	<Identification Standard="61499-1">
	</Identification>
	<VersionInfo Organization="Demmler Andreas Fahrzeugbau" Version="1.0" Author="Franz Höpfinger" Date="2026-06-30">
	</VersionInfo>
	<CompilerInfo packageName="isobus::pgn::const">
	</CompilerInfo>
	<GlobalConstants>
		<VarDeclaration Name="DC_NON_SPECIFIC_SYSTEM" Type="BYTE" Comment="Device Class / Vehicle System: Non-specific System" InitialValue="0"/>
		<VarDeclaration Name="DC_SYSTEM_TOOLS" Type="BYTE" Comment="Device Class / Vehicle System: System tools" InitialValue="10"/>
		<VarDeclaration Name="DC_SAFETY_SYSTEMS" Type="BYTE" Comment="Device Class / Vehicle System: Safety systems" InitialValue="20"/>
		<VarDeclaration Name="DC_GATEWAY" Type="BYTE" Comment="Device Class / Vehicle System: Gateway" InitialValue="25"/>
		<VarDeclaration Name="DC_POWER_MGMT_LIGHTING" Type="BYTE" Comment="Device Class / Vehicle System: Power management and lighting systems" InitialValue="30"/>
		<VarDeclaration Name="DC_STEERING_SYSTEMS" Type="BYTE" Comment="Device Class / Vehicle System: Steering systems" InitialValue="40"/>
		<VarDeclaration Name="DC_PROPULSION_SYSTEMS" Type="BYTE" Comment="Device Class / Vehicle System: Propulsion systems" InitialValue="50"/>
		<VarDeclaration Name="DC_NAVIGATION_SYSTEMS" Type="BYTE" Comment="Device Class / Vehicle System: Navigation systems" InitialValue="60"/>
		<VarDeclaration Name="DC_COMMUNICATIONS_SYSTEMS" Type="BYTE" Comment="Device Class / Vehicle System: Communications systems" InitialValue="70"/>
		<VarDeclaration Name="DC_INSTRUMENTATION_GENERAL" Type="BYTE" Comment="Device Class / Vehicle System: Instrumentation/general systems" InitialValue="80"/>
		<VarDeclaration Name="DC_ENVIRONMENTAL_HVAC" Type="BYTE" Comment="Device Class / Vehicle System: Environmental (HVAC) systems" InitialValue="90"/>
		<VarDeclaration Name="DC_DECK_CARGO_FISHING" Type="BYTE" Comment="Device Class / Vehicle System: Deck, cargo, and fishing equipment systems" InitialValue="100"/>
		<VarDeclaration Name="DC_NOT_AVAILABLE" Type="BYTE" Comment="Device Class / Vehicle System: Not Available" InitialValue="127"/>
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::pgn::const;

// Industry Group 4 specific device classes (vehicle systems)
GLOBALCONSTANTS IG4_Device_Classes
	VAR_GLOBAL CONSTANT
		DC_NON_SPECIFIC_SYSTEM : BYTE := 0; // Device Class / Vehicle System: Non-specific System
		DC_SYSTEM_TOOLS : BYTE := 10; // Device Class / Vehicle System: System tools
		DC_SAFETY_SYSTEMS : BYTE := 20; // Device Class / Vehicle System: Safety systems
		DC_GATEWAY : BYTE := 25; // Device Class / Vehicle System: Gateway
		DC_POWER_MGMT_LIGHTING : BYTE := 30; // Device Class / Vehicle System: Power management and lighting systems
		DC_STEERING_SYSTEMS : BYTE := 40; // Device Class / Vehicle System: Steering systems
		DC_PROPULSION_SYSTEMS : BYTE := 50; // Device Class / Vehicle System: Propulsion systems
		DC_NAVIGATION_SYSTEMS : BYTE := 60; // Device Class / Vehicle System: Navigation systems
		DC_COMMUNICATIONS_SYSTEMS : BYTE := 70; // Device Class / Vehicle System: Communications systems
		DC_INSTRUMENTATION_GENERAL : BYTE := 80; // Device Class / Vehicle System: Instrumentation/general systems
		DC_ENVIRONMENTAL_HVAC : BYTE := 90; // Device Class / Vehicle System: Environmental (HVAC) systems
		DC_DECK_CARGO_FISHING : BYTE := 100; // Device Class / Vehicle System: Deck, cargo, and fishing equipment systems
		DC_NOT_AVAILABLE : BYTE := 127; // Device Class / Vehicle System: Not Available
	END_VAR

END_GLOBALCONSTANTS
]]></OriginalSource>
</GlobalConstants>
