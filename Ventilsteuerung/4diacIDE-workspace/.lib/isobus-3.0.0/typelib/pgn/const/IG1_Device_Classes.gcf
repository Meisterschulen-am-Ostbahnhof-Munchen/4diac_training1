<?xml version="1.0" encoding="UTF-8"?>
<GlobalConstants Name="IG1_Device_Classes" Comment="Industry Group 1 specific device classes (vehicle systems)">
	<Identification Standard="61499-1">
	</Identification>
	<VersionInfo Organization="Demmler Andreas Fahrzeugbau" Version="1.0" Author="Franz Höpfinger" Date="2026-06-30">
	</VersionInfo>
	<CompilerInfo packageName="isobus::pgn::const">
	</CompilerInfo>
	<GlobalConstants>
		<VarDeclaration Name="DC_NON_SPECIFIC_SYSTEM" Type="BYTE" Comment="Device Class / Vehicle System: Non-specific System" InitialValue="0"/>
		<VarDeclaration Name="DC_TRACTOR" Type="BYTE" Comment="Device Class / Vehicle System: Tractor" InitialValue="1"/>
		<VarDeclaration Name="DC_TRAILER" Type="BYTE" Comment="Device Class / Vehicle System: Trailer" InitialValue="2"/>
		<VarDeclaration Name="DC_NOT_AVAILABLE" Type="BYTE" Comment="Device Class / Vehicle System: Not Available" InitialValue="127"/>
	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::pgn::const;

// Industry Group 1 specific device classes (vehicle systems)
GLOBALCONSTANTS IG1_Device_Classes
	VAR_GLOBAL CONSTANT
		DC_NON_SPECIFIC_SYSTEM : BYTE := 0; // Device Class / Vehicle System: Non-specific System
		DC_TRACTOR : BYTE := 1; // Device Class / Vehicle System: Tractor
		DC_TRAILER : BYTE := 2; // Device Class / Vehicle System: Trailer
		DC_NOT_AVAILABLE : BYTE := 127; // Device Class / Vehicle System: Not Available
	END_VAR

END_GLOBALCONSTANTS
]]></OriginalSource>
</GlobalConstants>
