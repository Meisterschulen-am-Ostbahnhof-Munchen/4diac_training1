		<VarDeclaration Name="F_BODY_TO_VEHICLE_INTERFACE_CONTROL" Type="BYTE" Comment="Sys: Non-specific System, Func: Body-to-Vehicle Interface Control - Interface controller managing" InitialValue="131"/>
		<VarDeclaration Name="F_SLOPE_SENSOR" Type="BYTE" Comment="Sys: Non-specific System, Func: Slope Sensor - Sensor for measuring a slope along an axis." InitialValue="132"/>
		<VarDeclaration Name="F_RETARDER_DISPLAY" Type="BYTE" Comment="Sys: Non-specific System, Func: Retarder Display - Display module that shows information" InitialValue="134"/>
		<VarDeclaration Name="F_DIFFERENTIAL_LOCK_CONTROLLER" Type="BYTE" Comment="Sys: Non-specific System, Func: Differential Lock Controller" InitialValue="135"/>
		<VarDeclaration Name="F_LOW_VOLTAGE_DISCONNECT" Type="BYTE" Comment="Sys: Non-specific System, Func: Low-Voltage Disconnect - The device that monitors the voltage of" InitialValue="136"/>
		<VarDeclaration Name="F_ROADWAY_INFORMATION" Type="BYTE" Comment="Sys: Non-specific System, Func: Roadway Information - Devices that use this function will provide" InitialValue="137"/>
		<VarDeclaration Name="F_AUTOMATED_DRIVING" Type="BYTE" Comment="Sys: Non-specific System, Func: Automated Driving - Automated Driving System. Note: The hardware" InitialValue="138"/>
		<VarDeclaration Name="F_NOT_AVAILABLE" Type="BYTE" Comment="Sys: Non-specific System, Func: Not Available - This assignment can be used until an explicit" InitialValue="255"/>
		<VarDeclaration Name="F_TRACTOR_FORWARD_ROAD_IMAGE_PROCESSING" Type="BYTE" Comment="Sys: Tractor, Func: Forward Road Image Processing - Determine vehicle position from lane" InitialValue="128"/>
		<VarDeclaration Name="F_TRACTOR_FIFTH_WHEEL_SMART_SYSTEM" Type="BYTE" Comment="Sys: Tractor, Func: Fifth Wheel Smart System - Any systems relative to the operation &amp;" InitialValue="129"/>
		<VarDeclaration Name="F_TRACTOR_CATALYST_FLUID_SENSOR" Type="BYTE" Comment="Sys: Tractor, Func: Catalyst Fluid Sensor - The Catalyst Fluid Sensor can measure the catalyst" InitialValue="130"/>
		<VarDeclaration Name="F_TRACTOR_ADAPTIVE_FRONT_LIGHTING_SYSTEM" Type="BYTE" Comment="Sys: Tractor, Func: Adaptive Front Lighting System - System used to adjust the vehicle front" InitialValue="131"/>
		<VarDeclaration Name="F_TRACTOR_IDLE_CONTROL_SYSTEM" Type="BYTE" Comment="Sys: Tractor, Func: Idle Control System - The device automatically starts and stops the engine" InitialValue="132"/>
