		<VarDeclaration Name="SA_RESERVED_128" Type="BYTE" Comment="Source Address: thru 207 are reserved for future assignment by SAE - Used for dynamic address" InitialValue="128"/>
		<VarDeclaration Name="SA_RESERVED_208" Type="BYTE" Comment="Source Address: thru 223 are reserved for future assignment - Used for individual preassigned" InitialValue="208"/>
		<VarDeclaration Name="SA_ROTATION_SENSOR" Type="BYTE" Comment="Source Address: Rotation Sensor - A device that measures the rotational angle around an axis." InitialValue="224"/>
		<VarDeclaration Name="SA_LIFT_ARM_CONTROLLER" Type="BYTE" Comment="Source Address: Lift Arm Controller - Controls the lift arms and tilt functions on a construction" InitialValue="225"/>
		<VarDeclaration Name="SA_SLOPE_SENSOR" Type="BYTE" Comment="Source Address: Slope Sensor - A device that measures the slope along an axis." InitialValue="226"/>
		<VarDeclaration Name="SA_MAIN_CONTROLLER_SKID_STEER_LOADER" Type="BYTE" Comment="Source Address: Main Controller - Skid Steer Loader - Primary system controller for skid steer" InitialValue="227"/>
		<VarDeclaration Name="SA_LOADER_CONTROL" Type="BYTE" Comment="Source Address: Loader Control - Controls the hydraulic system of the loader attachment of a" InitialValue="228"/>
		<VarDeclaration Name="SA_LASER_TRACER" Type="BYTE" Comment="Source Address: Laser Tracer - A device that receives a laser strike and reports the vertical and" InitialValue="229"/>
		<VarDeclaration Name="SA_LAND_LEVELING_SYSTEM_DISPLAY" Type="BYTE" Comment="Source Address: Land Leveling System Display - This device displays position information at a" InitialValue="230"/>
		<VarDeclaration Name="SA_SINGLE_LAND_LEVELING_SYSTEM_SUPERVISOR" Type="BYTE" Comment="Source Address: Single Land Leveling System Supervisor - This device is the Land Leveling System" InitialValue="231"/>
		<VarDeclaration Name="SA_LAND_LEVELING_ELECTRIC_MAST" Type="BYTE" Comment="Source Address: Land Leveling Electric Mast - A device that moves a Sensor to maintain a specific" InitialValue="232"/>
		<VarDeclaration Name="SA_SINGLE_LAND_LEVELING_SYSTEM_OPERATOR_INTERFACE" Type="BYTE" Comment="Source Address: Single Land Leveling System Operator Interface - A component that allows the user" InitialValue="233"/>
		<VarDeclaration Name="SA_LASER_RECEIVER" Type="BYTE" Comment="Source Address: Laser Receiver - A device that receives a laser strike, and reports the specific" InitialValue="234"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_1" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #1" InitialValue="235"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_2" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #2" InitialValue="236"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_3" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #3" InitialValue="237"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_4" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #4" InitialValue="238"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_5" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #5" InitialValue="239"/>
		<VarDeclaration Name="SA_SUPPLEMENTAL_SENSOR_PROCESSING_UNIT_6" Type="BYTE" Comment="Source Address: Supplemental Sensor Processing Unit #6" InitialValue="240"/>
