	<OriginalSource><![CDATA[PACKAGE isobus::pgn::const;

// Industry Group 3 specific device classes (vehicle systems)
GLOBALCONSTANTS IG3_Device_Classes
	VAR_GLOBAL CONSTANT
		DC_NON_SPECIFIC_SYSTEM : BYTE := 0; // Device Class / Vehicle System: Non-specific system
		DC_SKID_STEER_LOADER : BYTE := 1; // Device Class / Vehicle System: Skid Steer Loader
		DC_ARTICULATED_DUMP_TRUCK : BYTE := 2; // Device Class / Vehicle System: Articulated Dump Truck
		DC_BACKHOE : BYTE := 3; // Device Class / Vehicle System: Backhoe
		DC_CRAWLER : BYTE := 4; // Device Class / Vehicle System: Crawler
		DC_EXCAVATOR : BYTE := 5; // Device Class / Vehicle System: Excavator
		DC_FORKLIFT : BYTE := 6; // Device Class / Vehicle System: Forklift
		DC_FOUR_WHEEL_DRIVE_LOADER : BYTE := 7; // Device Class / Vehicle System: Four Wheel Drive Loader
		DC_GRADER : BYTE := 8; // Device Class / Vehicle System: Grader
		DC_MILLING_MACHINE : BYTE := 9; // Device Class / Vehicle System: Milling Machine
		DC_RECYCLER_AND_SOIL_STABILIZER : BYTE := 10; // Device Class / Vehicle System: Recycler and Soil Stabilizer
		DC_BINDING_AGENT_SPREADER : BYTE := 11; // Device Class / Vehicle System: Binding Agent Spreader
		DC_PAVER : BYTE := 12; // Device Class / Vehicle System: Paver
		DC_FEEDER : BYTE := 13; // Device Class / Vehicle System: Feeder
		DC_SCREENING_PLANT : BYTE := 14; // Device Class / Vehicle System: Screening Plant
		DC_STACKER : BYTE := 15; // Device Class / Vehicle System: Stacker
		DC_ROLLER : BYTE := 16; // Device Class / Vehicle System: Roller
		DC_CRUSHER : BYTE := 17; // Device Class / Vehicle System: Crusher
		DC_NOT_AVAILABLE : BYTE := 127; // Device Class / Vehicle System: Not Available
	END_VAR

END_GLOBALCONSTANTS
]]></OriginalSource>
