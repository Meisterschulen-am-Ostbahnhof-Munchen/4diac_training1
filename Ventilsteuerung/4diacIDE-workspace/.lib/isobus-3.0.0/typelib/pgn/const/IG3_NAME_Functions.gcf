		<VarDeclaration Name="F_BINDING_AGENT_SPREADER_NOT_AVAILABLE" Type="BYTE" Comment="Sys: Binding Agent Spreader, Func: Not Available - Spreading large quantities of binding agents" InitialValue="255"/>
