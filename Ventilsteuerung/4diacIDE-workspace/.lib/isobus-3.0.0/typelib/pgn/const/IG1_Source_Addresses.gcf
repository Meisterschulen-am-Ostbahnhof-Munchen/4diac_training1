		<VarDeclaration Name="SA_DOOR_CONTROLLER_2" Type="BYTE" Comment="Source Address: Door Controller #2 - cab codrivers side or second door" InitialValue="237"/>
		<VarDeclaration Name="SA_TACHOGRAPH" Type="BYTE" Comment="Source Address: Tachograph" InitialValue="238"/>
		<VarDeclaration Name="SA_ELECTRIC_PROPULSION_CONTROL_UNIT_1" Type="BYTE" Comment="Source Address: Electric Propulsion Control Unit #1 - First or only on-board device converting" InitialValue="239"/>
		<VarDeclaration Name="SA_ELECTRIC_PROPULSION_CONTROL_UNIT_2" Type="BYTE" Comment="Source Address: Electric Propulsion Control Unit #2 - Second on-board device converting torque" InitialValue="240"/>
		<VarDeclaration Name="SA_WWH_OBD_TESTER" Type="BYTE" Comment="Source Address: WWH-OBD Tester - SA for OBD tester as defined in WWH-OBD ISO 15765-4. Note that" InitialValue="241"/>
		<VarDeclaration Name="SA_ELECTRIC_PROPULSION_CONTROL_UNIT_4" Type="BYTE" Comment="Source Address: Electric Propulsion Control Unit #4 - Fourth on-board device converting torque" InitialValue="242"/>
		<VarDeclaration Name="SA_BATTERY_PACK_MONITOR_1" Type="BYTE" Comment="Source Address: Battery Pack Monitor #1 - Device to monitor battery pack #1" InitialValue="243"/>
		<VarDeclaration Name="SA_BATTERY_PACK_MONITOR_2_APU_4" Type="BYTE" Comment="Source Address: Battery Pack Monitor #2 / APU #4 - SA for either the device to monitor battery" InitialValue="244"/>
		<VarDeclaration Name="SA_BATTERY_PACK_MONITOR_3_APU_3" Type="BYTE" Comment="Source Address: Battery Pack Monitor #3 / APU #3 - SA for either the device to monitor battery" InitialValue="245"/>
