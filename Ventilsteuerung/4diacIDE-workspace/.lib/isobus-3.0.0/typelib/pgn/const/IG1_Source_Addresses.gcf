	</GlobalConstants>
	<OriginalSource><![CDATA[PACKAGE isobus::pgn::const;

// Industry Group 1 specific source addresses
GLOBALCONSTANTS IG1_Source_Addresses
	VAR_GLOBAL CONSTANT
		SA_RESERVED_128 : BYTE := 128; // Source Address: thru 158 are reserved for future assignment by SAE but available for use by self
		                               // configurable ECUs - Used for dynamic address assignment
		SA_AUTOMATED_DRIVING_CONTROLLER_2 : BYTE := 156; // Source Address: Automated Driving Controller 2 - Second Automated Driving Controller Notes: The
		                                                 // hardware and software that are collectively capable of performing some or all of the dynamic
		                                                 // driving ...
		SA_ELECTRIC_PROPULSION_CONTROL_UNIT_3 : BYTE := 157; // Source Address: Electric Propulsion Control Unit #3 - Third on-board device converting torque
		                                                     // commands to current commands in an electric vehicle system. Note that some applications have used
		                                                     // SA 24...
		SA_AUTOMATED_DRIVING_CONTROLLER_1 : BYTE := 158; // Source Address: Automated Driving Controller 1 - Automated Driving Controller. Notes: The
		                                                 // hardware and software that are collectively capable of performing some or all of the dynamic
		                                                 // driving task o...
		SA_ROADWAY_INFORMATION_SYSTEM : BYTE := 159; // Source Address: Roadway Information System - Controller applications that use this source address
		                                             // will provide information relevant to the roadway in which the vehicle is traveling. This includes
		                                             // i...
		SA_ADVANCED_EMERGENCY_BRAKING_SYSTEM : BYTE := 160; // Source Address: Advanced emergency braking system - A system which can detect a potential forward
		                                                    // collision and automatically activate the vehicle braking system to decelerate the vehicle with
		                                                    // the ...
		SA_FIFTH_WHEEL_SMART_SYSTEMS : BYTE := 161; // Source Address: Fifth Wheel Smart Systems - Any systems relative to the operation & status/safety
		                                            // monitoring of the fifth wheel coupler system (including mounting bracket).
		SA_SLOPE_SENSOR : BYTE := 162; // Source Address: Slope Sensor - A device that measures the slope along an axis.
		SA_CATALYST_FLUID_SENSOR : BYTE := 163; // Source Address: Catalyst Fluid Sensor - The Catalyst Fluid Sensor can measure the catalyst fluid
		                                        // temperature, the catalyst fluid level and the catalyst fluid quality.
		SA_ON_BOARD_DIAGNOSTIC_UNIT_2 : BYTE := 164; // Source Address: On Board Diagnostic Unit #2 - Controller used to report On Board Diagnostics
		SA_REAR_STEERING_AXLE_CONTROLLER_2 : BYTE := 165; // Source Address: Rear Steering Axle Controller #2 - Rear steering controller 2 for axle group
		SA_REAR_STEERING_AXLE_CONTROLLER_3 : BYTE := 166; // Source Address: Rear Steering Axle Controller #3 - Rear steering controller 3 for axle group
		SA_INSTRUMENT_CLUSTER_2 : BYTE := 167; // Source Address: Instrument Cluster #2 - A second optional, or auxiliary, gauge display for a
		                                       // vehicle
		SA_TRAILER_5_BRIDGE : BYTE := 168; // Source Address: Trailer #5 Bridge - Bridge for fifth towed Vehicle System (e.g. trailer or dolly)
		SA_TRAILER_5_LIGHTING_ELECTRICAL : BYTE := 169; // Source Address: Trailer #5 Lighting-electrical
		SA_TRAILER_5_BRAKES_ABS_EBS : BYTE := 170; // Source Address: Trailer #5 Brakes (ABS-EBS)
		SA_TRAILER_5_REEFER : BYTE := 171; // Source Address: Trailer #5 Reefer
		SA_TRAILER_5_CARGO : BYTE := 172; // Source Address: Trailer #5 Cargo
		SA_TRAILER_5_CHASSIS_SUSPENSION : BYTE := 173; // Source Address: Trailer #5 Chassis-Suspension
		SA_OTHER_TRAILER_5_DEVICES : BYTE := 174; // Source Address: Other Trailer #5 Devices - Recommended address space for subnetwork devices
		SA_OTHER_TRAILER_5_DEVICES_175 : BYTE := 175; // Source Address: Other Trailer #5 Devices - Recommended address space for subnetwork devices
		SA_TRAILER_4_BRIDGE : BYTE := 176; // Source Address: Trailer #4 Bridge - Bridge for fourth towed Vehicle System (e.g. trailer or
		                                   // dolly)
		SA_TRAILER_4_LIGHTING_ELECTRICAL : BYTE := 177; // Source Address: Trailer #4 Lighting-electrical
		SA_TRAILER_4_BRAKES_ABS_EBS : BYTE := 178; // Source Address: Trailer #4 Brakes (ABS-EBS)
		SA_TRAILER_4_REEFER : BYTE := 179; // Source Address: Trailer #4 Reefer
		SA_TRAILER_4_CARGO : BYTE := 180; // Source Address: Trailer #4 Cargo
		SA_TRAILER_4_CHASSIS_SUSPENSION : BYTE := 181; // Source Address: Trailer #4 Chassis-Suspension
		SA_OTHER_TRAILER_4_DEVICES : BYTE := 182; // Source Address: Other Trailer #4 Devices - Recommended address space for subnetwork devices
		SA_OTHER_TRAILER_4_DEVICES_183 : BYTE := 183; // Source Address: Other Trailer #4 Devices - Recommended address space for subnetwork devices
		SA_TRAILER_3_BRIDGE : BYTE := 184; // Source Address: Trailer #3 Bridge - Bridge for third towed Vehicle System (e.g. trailer or dolly)
		SA_TRAILER_3_LIGHTING_ELECTRICAL : BYTE := 185; // Source Address: Trailer #3 Lighting-electrical
		SA_TRAILER_3_BRAKES_ABS_EBS : BYTE := 186; // Source Address: Trailer #3 Brakes (ABS-EBS)
		SA_TRAILER_3_REEFER : BYTE := 187; // Source Address: Trailer #3 Reefer
		SA_TRAILER_3_CARGO : BYTE := 188; // Source Address: Trailer #3 Cargo
		SA_TRAILER_3_CHASSIS_SUSPENSION : BYTE := 189; // Source Address: Trailer #3 Chassis-Suspension
		SA_OTHER_TRAILER_3_DEVICES : BYTE := 190; // Source Address: Other Trailer #3 Devices - Recommended address space for subnetwork devices
		SA_OTHER_TRAILER_3_DEVICES_191 : BYTE := 191; // Source Address: Other Trailer #3 Devices - Recommended address space for subnetwork devices
		SA_TRAILER_2_BRIDGE : BYTE := 192; // Source Address: Trailer #2 Bridge - Bridge for second towed Vehicle System (e.g. trailer or
		                                   // dolly)
		SA_TRAILER_2_LIGHTING_ELECTRICAL : BYTE := 193; // Source Address: Trailer #2 Lighting-electrical
		SA_TRAILER_2_BRAKES_ABS_EBS : BYTE := 194; // Source Address: Trailer #2 Brakes (ABS-EBS)
		SA_TRAILER_2_REEFER : BYTE := 195; // Source Address: Trailer #2 Reefer
		SA_TRAILER_2_CARGO : BYTE := 196; // Source Address: Trailer #2 Cargo
		SA_TRAILER_2_CHASSIS_SUSPENSION : BYTE := 197; // Source Address: Trailer #2 Chassis-Suspension
		SA_OTHER_TRAILER_2_DEVICES : BYTE := 198; // Source Address: Other Trailer #2 Devices - Recommended address space for subnetwork devices
		SA_OTHER_TRAILER_2_DEVICES_199 : BYTE := 199; // Source Address: Other Trailer #2 Devices - Recommended address space for subnetwork devices
		SA_TRAILER_1_BRIDGE : BYTE := 200; // Source Address: Trailer #1 Bridge - Bridge for first towed Vehicle System (e.g. trailer or dolly)
		SA_TRAILER_1_LIGHTING_ELECTRICAL : BYTE := 201; // Source Address: Trailer #1 Lighting-electrical
		SA_TRAILER_1_BRAKES_ABS_EBS : BYTE := 202; // Source Address: Trailer #1 Brakes (ABS-EBS)
		SA_TRAILER_1_REEFER : BYTE := 203; // Source Address: Trailer #1 Reefer
		SA_TRAILER_1_CARGO : BYTE := 204; // Source Address: Trailer #1 Cargo
		SA_TRAILER_1_CHASSIS_SUSPENSION : BYTE := 205; // Source Address: Trailer #1 Chassis-Suspension
		SA_OTHER_TRAILER_1_DEVICES : BYTE := 206; // Source Address: Other Trailer #1 Devices - Recommended address space for subnetwork devices
		SA_OTHER_TRAILER_1_DEVICES_207 : BYTE := 207; // Source Address: Other Trailer #1 Devices - Recommended address space for subnetwork devices
		SA_RESERVED_208 : BYTE := 208; // Source Address: thru 227 are reserved for future assignment by SAE - To be used for individual
		                               // preassigned addresses
		SA_STEERING_INPUT_UNIT : BYTE := 228; // Source Address: Steering Input Unit - May be used for measuring steering angle, steering torsion,
		                                      // steering force feedback, etc.
		SA_BODY_CONTROLLER_2 : BYTE := 229; // Source Address: Body Controller #2 - This is for the second instance of a body controller on a
		                                    // chassis.
		SA_BODY_TO_VEHICLE_INTERFACE_CONTROL : BYTE := 230; // Source Address: Body-to-Vehicle Interface Control - Interface controller managing interaction of
		                                                    // vehicle functions and body functions. May be a combination of body signals and gateway
		                                                    // functionalities.
		SA_ARTICULATION_TURNTABLE_CONTROL : BYTE := 231; // Source Address: Articulation Turntable Control - Controller managing the articulation turntable
		                                                 // for joined body buses.
		SA_FORWARD_ROAD_IMAGE_PROCESSOR : BYTE := 232; // Source Address: Forward Road Image Processor - Views the road ahead for electronic recognition of
		                                               // several items
		SA_DOOR_CONTROLLER_3 : BYTE := 233; // Source Address: Door Controller #3
		SA_DOOR_CONTROLLER_4 : BYTE := 234; // Source Address: Door Controller #4
		SA_TRACTOR_TRAILER_BRIDGE_2 : BYTE := 235; // Source Address: Tractor/Trailer Bridge #2 - Second tractor mounted bridge leading to trailer(s)
		SA_DOOR_CONTROLLER_1 : BYTE := 236; // Source Address: Door Controller #1 - cab drivers side or first door
		SA_DOOR_CONTROLLER_2 : BYTE := 237; // Source Address: Door Controller #2 - cab codrivers side or second door
		SA_TACHOGRAPH : BYTE := 238; // Source Address: Tachograph
		SA_ELECTRIC_PROPULSION_CONTROL_UNIT_1 : BYTE := 239; // Source Address: Electric Propulsion Control Unit #1 - First or only on-board device converting
		                                                     // torque commands to current commands in an electric vehicle system
		SA_ELECTRIC_PROPULSION_CONTROL_UNIT_2 : BYTE := 240; // Source Address: Electric Propulsion Control Unit #2 - Second on-board device converting torque
		                                                     // commands to current commands in an electric vehicle system
		SA_WWH_OBD_TESTER : BYTE := 241; // Source Address: WWH-OBD Tester - SA for OBD tester as defined in WWH-OBD ISO 15765-4. Note that
		                                 // some applications use this SA for Electric Propulsion Control Unit #3.
		SA_ELECTRIC_PROPULSION_CONTROL_UNIT_4 : BYTE := 242; // Source Address: Electric Propulsion Control Unit #4 - Fourth on-board device converting torque
		                                                     // commands to current commands in an electric vehicle system
		SA_BATTERY_PACK_MONITOR_1 : BYTE := 243; // Source Address: Battery Pack Monitor #1 - Device to monitor battery pack #1
		SA_BATTERY_PACK_MONITOR_2_APU_4 : BYTE := 244; // Source Address: Battery Pack Monitor #2 / APU #4 - SA for either the device to monitor battery
		                                               // pack #2 or APU #4
		SA_BATTERY_PACK_MONITOR_3_APU_3 : BYTE := 245; // Source Address: Battery Pack Monitor #3 / APU #3 - SA for either the device to monitor battery
		                                               // pack #3 or APU #3
		SA_BATTERY_PACK_MONITOR_4_APU_2 : BYTE := 246; // Source Address: Battery Pack Monitor #4 / APU #2 - SA for either the device to monitor battery
		                                               // pack #4 or APU #2
		SA_AUXILIARY_POWER_UNIT_APU_1 : BYTE := 247; // Source Address: Auxiliary Power Unit (APU) #1 - Device used to provide auxiliary power, such as
		                                             // electrical, hydraulic, pneumatic, or rotary
	END_VAR

END_GLOBALCONSTANTS
]]></OriginalSource>
</GlobalConstants>
