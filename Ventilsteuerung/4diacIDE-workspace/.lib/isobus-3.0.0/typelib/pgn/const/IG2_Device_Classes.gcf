		DC_SKIDDER : BYTE := 16; // Device Class / Vehicle System: Skidder
		DC_SENSOR_SYSTEMS : BYTE := 17; // Device Class / Vehicle System: Sensor Systems
		DC_TIMBER_HARVESTERS : BYTE := 19; // Device Class / Vehicle System: Timber Harvesters
		DC_FORWARDERS : BYTE := 20; // Device Class / Vehicle System: Forwarders
		DC_TIMBER_LOADERS : BYTE := 21; // Device Class / Vehicle System: Timber Loaders
		DC_TIMBER_PROCESSING_MACHINES : BYTE := 22; // Device Class / Vehicle System: Timber Processing Machines
		DC_MULCHERS : BYTE := 23; // Device Class / Vehicle System: Mulchers
		DC_UTILITY_VEHICLES : BYTE := 24; // Device Class / Vehicle System: Utility Vehicles
		DC_SLURRY_MANURE_APPLICATORS : BYTE := 25; // Device Class / Vehicle System: Slurry/Manure Applicators
		DC_FEEDERS_MIXERS : BYTE := 26; // Device Class / Vehicle System: Feeders/Mixers
		DC_WEEDERS : BYTE := 27; // Device Class / Vehicle System: Weeders - Non-chemical weed control. The device class Weeders is
		                         // used by devices that control and eliminate weeds through the use of operation techniques other
		                         // than s...
		DC_TURF_AND_LAWN_CARE_MOWERS : BYTE := 28; // Device Class / Vehicle System: Turf and Lawn Care Mowers
		DC_PRODUCT_MATERIAL_HANDLING : BYTE := 29; // Device Class / Vehicle System: Product/Material Handling
		DC_NOT_AVAILABLE : BYTE := 127; // Device Class / Vehicle System: Not Available
	END_VAR

END_GLOBALCONSTANTS
]]></OriginalSource>
