	<OriginalSource><![CDATA[PACKAGE isobus::pgn::const;

// Industry non-specific function defines (other see
// https://www.isobus.net/isobus/nameFunction/index )
GLOBALCONSTANTS Global_NAME_Functions
	VAR_GLOBAL CONSTANT
		F_ENGINE : BYTE := 0; // Function: Engine - While the function identifies what is typically the mechanical power source of
		                      // the machine, the reference tends to be to the management system that controls the torque vs speed
		                      // v...
		F_AUX_POWER_UNIT : BYTE := 1; // Function: Auxiliary Power Unit (APU) - Power source for operating systems without the use of the
		                              // prime ‘drive’ engine.
		F_ELEC_PROPULSION_CONTROL : BYTE := 2; // Function: Electric Propulsion Control - Control system which operates the drive mechanism when it
		                                       // is electrically powered, such as battery-motor, or engine-generator-motor hybrids
		F_TRANSMISSION : BYTE := 3; // Function: Transmission - A mechanical system for alter the speed vs torque output of the engine
		                            // to a level usable by another system on the machine. Although again the network reference is
		                            // actually ...
		F_BATTERY_PACK_MONITOR : BYTE := 4; // Function: Battery Pack Monitor - Monitors the condition - charge, temperature, power remaining,
		                                    // etc. for an internal battery pack - typically used with electric propulsion
		F_SHIFT_CONTROL_CONSOLE : BYTE := 5; // Function: Shift Control/Console - The device which determines and transmit onto the network the
		                                     // gear, the range, the operating mode or any or all of these that the operator desires for the
		                                     // transmis...
		F_POWER_TAKEOFF_MAIN_OR_REAR : BYTE := 6; // Function: Power TakeOff - (Main or Rear) - The system which controls the mechanical power derived
		                                          // from a prime engine and used to operate auxiliary items such as compressors in on highway
		                                          // vehicles ...
		F_AXLE_STEERING : BYTE := 7; // Function: Axle - Steering - Adjust attack angle as function of steering
		F_AXLE_DRIVE : BYTE := 8; // Function: Axle - Drive
		F_BRAKES_SYSTEMCONTROL : BYTE := 9; // Function: Brakes - System Controller - Controls service braking system electronically – might be
		                                    // any of a number of schemes – may also control (at least partly) the endurance braking system in
		                                    // the ...
		F_BRAKES_STEER_AXLE : BYTE := 10; // Function: Brakes - Steer Axle - Control for actuating the service brakes on a steered axle
		F_BRAKES_DRIVE_AXLE : BYTE := 11; // Function: Brakes - Drive axle - Control for actuating the service brakes on a drive axle
		F_RETARDER_ENGINE : BYTE := 12; // Function: Retarder - Engine - The control for the retarder capabilities of the engine. There are
		                                // several types of retarders possible and these are defined within the parameter - Retarder Type,
		                                // (SPN...
		F_RETARDER_DRIVELINE : BYTE := 13; // Function: Retarder - Driveline - The control for the retarder capabilities of the driveline.
		                                   // There are several types of retarders possible and these are defined within the parameter -
		                                   // Retarder Type...
		F_CRUISE_CONTROL : BYTE := 14; // Function: Cruise Control - Control system for maintaining the vehicle’s speed at a fixed operator
		                               // selectable value with various over-rides linked to other systems
		F_FUEL_SYSTEM : BYTE := 15; // Function: Fuel System - Controls fuel flow from the tank to the filter to the
		                            // water-removal/separator to the engine and then back to the tank.
		F_STEERING_CONTROL : BYTE := 16; // Function: Steering Controller - Controls steering in steer-by-wire
		F_SUSPENSION_STEER_AXLE : BYTE := 17; // Function: Suspension - Steer Axle - Control system for the suspension of a steered axle
		F_SUSPENSION_DRIVE_AXLE : BYTE := 18; // Function: Suspension - Drive Axle - Control system for the suspension of a driven axle
		F_INSTRUMENT_CLUSTER : BYTE := 19; // Function: Instrument Cluster - A gauge display for a vehicle. Typically mounted in the cab within
		                                   // the driver’s field of view and generally a somewhat limited display such as: dedicated dials or a
		                                   // s...
		F_TRIP_RECORDER : BYTE := 20; // Function: Trip Recorder - A system for accumulating data versus travel of the vehicle (machine),
		                              // since a specific starting point sometimes expressed in terms of distance or time traveled.
		F_CAB_CLIMATE_CONTROL : BYTE := 21; // Function: Cab Climate Control - A system for controlling the climate within the cab of the
		                                    // vehicle (machine). Note: The operator controls (message) for this system should be designed to
		                                    // allow any s...
		F_AERODYNAMIC_CONTROL : BYTE := 22; // Function: Aerodynamic Control - Modify drag by altering Body panels – lower air ferrings when
		                                    // dead heading, extend side panels when on interstate
		F_VEHICLE_NAVIGATION : BYTE := 23; // Function: Vehicle Navigation - System associated with the vehicles physical location – may be as
		                                   // simple as display of current location, driving instructions from current to desired location, (do
		                                   // we...
		F_VEHICLE_SECURITY : BYTE := 24; // Function: Vehicle Security - System for comparing operator provided data sequences against
		                                 // reference to verify that operation or certain operations should be allowed for the particular
		                                 // operator. Al...
		F_NETWORK_INTERCONNECT_UNIT : BYTE := 25; // Function: Network Interconnect ECU - ECU for connecting different network segments together – may
		                                          // be bridge or gateway - see J1939 –31 for details For any vehicle system (tractor or trailer)
		F_BODY_CONTROLLER : BYTE := 26; // Function: Body Controller - May handle suspension control for the body sections independent from
		                                // the axle sections - Controls the body (not chassis or cab) components
		F_POWER_TAKEOFF_SECONDARY_OR_FRONT : BYTE := 27; // Function: Power TakeOff (Secondary or Front) - The system which controls the mechanical power
		                                                 // derived from a prime engine and used to operate auxiliary items such as compressors in on highway
		                                                 // vehic...
		F_OFF_VEHICLE_GATEWAY : BYTE := 28; // Function: Off Vehicle Gateway - ECU for connecting between vehicle network(s) and an off-vehicle
		                                    // system or network, such as fleet management. Connection may be wireless. Performs Gateway
		                                    // functions,...
		F_VTERMINAL : BYTE := 29; // Function: Virtual Terminal (in cab) - A general purpose ‘intelligent’ display with a specific
		                          // message set (J1939-72 or ISO 11783 –6) specifically mounted in cab for the operators use, which
		                          // may be ...
		F_MANAGEMENT_COMPUTER : BYTE := 30; // Function: Management Computer - Manages vehicle systems, i.e. powertrain.
		F_PROPULSION_BATTERY_CHARGER : BYTE := 31; // Function: Propulsion Battery Charger - A device used to charge propulsion batteries in an
		                                           // electric vehicle from an off-board source of electrical energy.
		F_HEADWAY_CONTROLLER : BYTE := 32; // Function: Headway Controller - Forward-looking collision avoidance, collision warning, speed
		                                   // controller, or speed matching
		F_SYSTEM_MONITOR : BYTE := 33; // Function: System Monitor
		F_HYDRAULIC_PUMP_CONTROLLER : BYTE := 34; // Function: Hydraulic Pump Controller - Pump which provides hydraulic power to operate installed
		                                          // equipment, such as: Man buckets, cranes, augers, shredders Example vehicles: Digger Derrick –
		                                          // plants t...
		F_SUSPENSION_SYSTEM_CONTROLLER : BYTE := 35; // Function: Suspension - System Controller - A controller responsible for co-ordinating the
		                                             // over-all suspension of a vehicle. It may cause inter action between the axle suspension controls
		                                             // and the bo...
		F_PNEUMATIC_SYSTEM_CONTROLLER : BYTE := 36; // Function: Pneumatic - System Controller
		F_CAB_CONTROLLER : BYTE := 37; // Function: Cab Controller - A controller located in/near vehicle cab to perform functions that are
		                               // grouped together for convenience and proximity. May handle any number of vehicle specific items
		                               // but...
		F_TIRE_PRESSURE_CONTROL : BYTE := 38; // Function: Tire Pressure Control - The device providing centralised tire inflation
		F_IGNITION_CONTROL_MODULE : BYTE := 39; // Function: Ignition Control Module - A device for altering the ignition of an engine and with
		                                        // which an engine controller may communicate.
		F_SEAT_CONTROL : BYTE := 40; // Function: Seat Control - A system for controlling the seats (operator and passenger) within the
		                             // cab of the vehicle (machine). May include position and suspension of seat. Note: The operator
		                             // control...
		F_LIGHTING_OPERATOR_CONTROLS : BYTE := 41; // Function: Lighting - Operator Controls - The controller for sending the operator lighting
		                                           // controls messages when they are coming from a device dedicated to transmitting these specific
		                                           // messages on t...
		F_WATER_PUMP_CONTROL : BYTE := 42; // Function: Water Pump Control - Controller for a water pump mounted on the vehicle/machine. For
		                                   // Instance – Emergency equipment with pump for pumping water onto fire. A Utilities delivery truck
		                                   // for d...
		F_TRANSMISSION_DISPLAY : BYTE := 43; // Function: Transmission Display - Display designed specifically to display transmission
		                                     // information, such as the transmission gear.
		F_EXHAUST_EMISSION_CONTROL : BYTE := 44; // Function: Exhaust Emission Control
		F_VEHICLE_DYNAMIC_STABILITY_CONTROL : BYTE := 45; // Function: Vehicle Dynamic Stability Control
		F_OIL_SENSOR_UNIT : BYTE := 46; // Function: Oil Sensor Unit
		F_INFORMATION_SYSTEM_CONTROLLER : BYTE := 47; // Function: Information System Controller - Information management for the vehicle's application,
		                                              // such as transit passenger/fare monitoring, truck cargo management, etc. Handles grouping and
		                                              // processi...
		F_RAMP_CONTROL : BYTE := 48; // Function: Ramp Control - Loading unloading – chairlift, ramps, lifts, or tailgates
		F_CLUTCH_CONVERTER_CONTROL : BYTE := 49; // Function: Clutch/Converter Control - When transmission is distributed this handles torque
		                                         // converter lock-up or engine - transmission connection
		F_AUXILIARY_HEATER : BYTE := 50; // Function: Auxiliary Heater - Primary heat is typically taken from the engine coolant. This is the
		                                 // heater for use without the prime ‘drive’ engine operating or when it is unable to supply
		                                 // sufficient...
		F_FORWARD_LOOKING_COLLISION_WARNING_SYSTEM : BYTE := 51; // Function: Forward-Looking Collision Warning System - A system which detects and warns of
		                                                         // impending collision with object in path of present forward travel - Not to be confused with #32,
		                                                         // Headway Con...
		F_CHASSIS_CONTROLLER : BYTE := 52; // Function: Chassis Controller - Controls the chassis (not body or cab) components
		F_ALTERNATOR_CHARGING_SYSTEM : BYTE := 53; // Function: Alternator/Charging System - Vehicle's primary on-board charging controller -
		                                           // Alternator used to generate electrical power for vehicle electrical system and storage battery.
		F_COMMUNICATIONS_UNIT_CELLULAR : BYTE := 54; // Function: Communications Unit, Cellular - Radio communications device designed specifically to
		                                             // communicate via the ‘Cellular telephone system’. May be either receiver only, transmitter only or
		                                             // tran...
		F_COMMUNICATIONS_UNIT_SATELLITE : BYTE := 55; // Function: Communications Unit, Satellite - Radio communications device designed specifically to
		                                              // communicate via some satellite system. May be either receiver only, transmitter only or
		                                              // transceiver.
		F_COMMUNICATIONS_UNIT_RADIO : BYTE := 56; // Function: Communications Unit, Radio - Radio communications device designed specifically to
		                                          // communicate via a terrestrial point to point system. May be either receiver only, transmitter
