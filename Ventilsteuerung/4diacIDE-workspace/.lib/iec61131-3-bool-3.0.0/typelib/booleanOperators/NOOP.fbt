<?xml version="1.0" encoding="UTF-8"?>
<FBType Name="NOOP" Comment="No-Op, also known as &quot;no Operation&quot;">
	<Identification Standard="61499-2">
	</Identification>
	<VersionInfo Version="1.0" Author="franz" Date="2026-05-05">
	</VersionInfo>
	<CompilerInfo packageName="iec61131::bitwiseOperators">
	</CompilerInfo>
	<InterfaceList>
		<EventInputs>
			<Event Name="INIT" Type="EInit" Comment="Initialization Request">
			</Event>
			<Event Name="REQ" Type="Event" Comment="Normal Execution Request">
				<With Var="IN"/>
			</Event>
		</EventInputs>
		<EventOutputs>
			<Event Name="INITO" Type="EInit" Comment="Initialization Confirm">
			</Event>
			<Event Name="CNF" Type="Event" Comment="Execution Confirmation">
				<With Var="OUT"/>
			</Event>
		</EventOutputs>
		<InputVars>
			<VarDeclaration Name="IN" Type="BOOL" Comment="Input"/>
		</InputVars>
		<OutputVars>
			<VarDeclaration Name="OUT" Type="BOOL" Comment="Output"/>
		</OutputVars>
	</InterfaceList>
	<FBNetwork>
		<FB Name="F_MOVE" Type="iec61131::selection::F_MOVE" x="300" y="-700">
			<Attribute Name="DataType" Value="BOOL"/>
		</FB>
		<EventConnections>
			<Connection Source="INIT" Destination="INITO"/>
			<Connection Source="REQ" Destination="F_MOVE.REQ" dx1="1123.53"/>
			<Connection Source="F_MOVE.CNF" Destination="CNF" dx1="1688.24"/>
		</EventConnections>
		<DataConnections>
			<Connection Source="IN" Destination="F_MOVE.IN" dx1="635.29"/>
			<Connection Source="F_MOVE.OUT" Destination="OUT" dx1="2947.06"/>
		</DataConnections>
	</FBNetwork>
</FBType>
